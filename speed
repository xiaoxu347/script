-- Roblox CFrame加速移动脚本（双模式版）
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer

local MOVE_CONFIG = {
    speed = 2,
    minSpeed = 1,
    maxSpeed = 10,
    speedStep = 0.5,
    isSpeedEnabled = false,
    isAnimMoveEnabled = false  -- 动画中移动模式
}

local speedConnection = nil
local animMoveConnection = nil
local lastPosition = nil

-- ============================================================
-- UI 创建
-- ============================================================
local function createControlPanel()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "SpeedControl"
    screenGui.Parent = game.CoreGui
    screenGui.ResetOnSpawn = false

    -- 主面板（加高以容纳新按钮）
    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0, 140, 0, 140)
    mainFrame.Position = UDim2.new(1, -150, 0, 10)
    mainFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    mainFrame.BackgroundTransparency = 0.2
    mainFrame.BorderSizePixel = 1
    mainFrame.BorderColor3 = Color3.fromRGB(255, 255, 255)
    mainFrame.Parent = screenGui

    -- 加速开关
    local speedButton = Instance.new("TextButton")
    speedButton.Size = UDim2.new(1, -10, 0, 30)
    speedButton.Position = UDim2.new(0, 5, 0, 5)
    speedButton.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
    speedButton.Text = "开启加速"
    speedButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    speedButton.TextScaled = true
    speedButton.Font = Enum.Font.SourceSansBold
    speedButton.Parent = mainFrame

    -- 速度显示
    local speedLabel = Instance.new("TextLabel")
    speedLabel.Size = UDim2.new(1, -10, 0, 18)
    speedLabel.Position = UDim2.new(0, 5, 0, 40)
    speedLabel.BackgroundTransparency = 1
    speedLabel.Text = "倍速: " .. MOVE_CONFIG.speed .. "x"
    speedLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    speedLabel.TextScaled = true
    speedLabel.Font = Enum.Font.SourceSans
    speedLabel.Parent = mainFrame

    -- 速度调节
    local speedDownButton = Instance.new("TextButton")
    speedDownButton.Size = UDim2.new(0, 60, 0, 25)
    speedDownButton.Position = UDim2.new(0, 5, 0, 65)
    speedDownButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    speedDownButton.Text = "-"
    speedDownButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    speedDownButton.TextScaled = true
    speedDownButton.Font = Enum.Font.SourceSansBold
    speedDownButton.Parent = mainFrame

    local speedUpButton = Instance.new("TextButton")
    speedUpButton.Size = UDim2.new(0, 60, 0, 25)
    speedUpButton.Position = UDim2.new(0, 75, 0, 65)
    speedUpButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    speedUpButton.Text = "+"
    speedUpButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    speedUpButton.TextScaled = true
    speedUpButton.Font = Enum.Font.SourceSansBold
    speedUpButton.Parent = mainFrame

    -- 【新增】动画中移动模式按钮
    local animMoveButton = Instance.new("TextButton")
    animMoveButton.Size = UDim2.new(1, -10, 0, 30)
    animMoveButton.Position = UDim2.new(0, 5, 0, 100)
    animMoveButton.BackgroundColor3 = Color3.fromRGB(0, 80, 170)
    animMoveButton.Text = "动画移动: 关"
    animMoveButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    animMoveButton.TextScaled = true
    animMoveButton.Font = Enum.Font.SourceSansBold
    animMoveButton.Parent = mainFrame

    return {
        speedButton = speedButton,
        speedLabel = speedLabel,
        speedUpButton = speedUpButton,
        speedDownButton = speedDownButton,
        animMoveButton = animMoveButton
    }
end

-- ============================================================
-- 工具函数
-- ============================================================
local function getCharacterParts()
    local character = LocalPlayer.Character
    if not character then return nil, nil, nil end
    local humanoid = character:FindFirstChild("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    return humanoid, rootPart, character
end

local function forceMove(rootPart, humanoid, newCFrame)
    if rootPart.Anchored then
        rootPart.Anchored = false
    end
    for _, v in ipairs(rootPart:GetChildren()) do
        if v:IsA("BodyPosition") or v:IsA("BodyVelocity")
            or v:IsA("AlignPosition") or v:IsA("VectorForce") then
            v:Destroy()
        end
    end
    if humanoid.WalkSpeed == 0 then
        humanoid.WalkSpeed = 16
    end
    rootPart.CFrame = newCFrame
    rootPart.AssemblyLinearVelocity = Vector3.new(
        0,
        rootPart.AssemblyLinearVelocity.Y,
        0
    )
end

-- ============================================================
-- 模式一：普通加速（Heartbeat，位置差驱动）
-- ============================================================
local function stopCFrameSpeed()
    if speedConnection then
        speedConnection:Disconnect()
        speedConnection = nil
    end
    lastPosition = nil
end

local function startCFrameSpeed()
    if speedConnection then return end

    local humanoid, rootPart = getCharacterParts()
    if not humanoid or not rootPart then return end

    lastPosition = rootPart.CFrame.Position

    speedConnection = RunService.Heartbeat:Connect(function()
        local humanoid, rootPart = getCharacterParts()
        if not humanoid or not rootPart then stopCFrameSpeed() return end

        local state = humanoid:GetState()
        if state == Enum.HumanoidStateType.Dead then return end
        if state == Enum.HumanoidStateType.Seated then
            lastPosition = rootPart.CFrame.Position
            return
        end

        local currentPosition = rootPart.CFrame.Position
        local moveDirection = currentPosition - lastPosition

        if moveDirection.Magnitude > 0.01 then
            local horizontalMove = Vector3.new(moveDirection.X, 0, moveDirection.Z)
            if horizontalMove.Magnitude > 0.01 then
                local acceleratedMove = horizontalMove * MOVE_CONFIG.speed
                local newPosition = lastPosition + acceleratedMove
                local rotCFrame = rootPart.CFrame - rootPart.CFrame.Position
                rootPart.CFrame = CFrame.new(
                    Vector3.new(newPosition.X, currentPosition.Y, newPosition.Z)
                ) * rotCFrame
                rootPart.AssemblyLinearVelocity = Vector3.new(
                    0, rootPart.AssemblyLinearVelocity.Y, 0
                )
            end
        end

        lastPosition = rootPart.CFrame.Position
    end)
end

-- ============================================================
-- 模式二：动画中移动（RenderStepped，MoveDirection驱动）
-- ============================================================
local function stopAnimMove()
    if animMoveConnection then
        animMoveConnection:Disconnect()
        animMoveConnection = nil
    end
end

local function startAnimMove()
    if animMoveConnection then return end

    local humanoid, rootPart = getCharacterParts()
    if not humanoid or not rootPart then return end

    animMoveConnection = RunService.RenderStepped:Connect(function(dt)
        local humanoid, rootPart = getCharacterParts()
        if not humanoid or not rootPart then stopAnimMove() return end

        local state = humanoid:GetState()
        if state == Enum.HumanoidStateType.Dead then return end
        if state == Enum.HumanoidStateType.Seated then return end

        local moveDir = humanoid.MoveDirection
        if moveDir.Magnitude > 0.01 then
            local currentPosition = rootPart.CFrame.Position
            local baseSpeed = math.max(humanoid.WalkSpeed, 16)
            local frameMove = moveDir * baseSpeed * MOVE_CONFIG.speed * dt
            local newPosition = Vector3.new(
                currentPosition.X + frameMove.X,
                currentPosition.Y,
                currentPosition.Z + frameMove.Z
            )
            local rotCFrame = rootPart.CFrame - rootPart.CFrame.Position
            local newCFrame = CFrame.new(newPosition) * rotCFrame
            forceMove(rootPart, humanoid, newCFrame)
        end
    end)
end

-- ============================================================
-- 切换函数
-- ============================================================
local function toggleSpeed(elements)
    MOVE_CONFIG.isSpeedEnabled = not MOVE_CONFIG.isSpeedEnabled
    if MOVE_CONFIG.isSpeedEnabled then
        startCFrameSpeed()
        elements.speedButton.Text = "关闭加速"
        elements.speedButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
    else
        stopCFrameSpeed()
        elements.speedButton.Text = "开启加速"
        elements.speedButton.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
    end
end

local function toggleAnimMove(elements)
    MOVE_CONFIG.isAnimMoveEnabled = not MOVE_CONFIG.isAnimMoveEnabled
    if MOVE_CONFIG.isAnimMoveEnabled then
        startAnimMove()
        elements.animMoveButton.Text = "动画移动: 开"
        elements.animMoveButton.BackgroundColor3 = Color3.fromRGB(0, 170, 100)
    else
        stopAnimMove()
        elements.animMoveButton.Text = "动画移动: 关"
        elements.animMoveButton.BackgroundColor3 = Color3.fromRGB(0, 80, 170)
    end
end

local function updateSpeedLabel(elements)
    elements.speedLabel.Text = "倍速: " .. MOVE_CONFIG.speed .. "x"
end

local function adjustSpeed(change, elements)
    MOVE_CONFIG.speed = math.max(MOVE_CONFIG.minSpeed,
        math.min(MOVE_CONFIG.maxSpeed, MOVE_CONFIG.speed + change))
    updateSpeedLabel(elements)
end

-- ============================================================
-- 角色重生处理
-- ============================================================
local function setupCharacterListener()
    LocalPlayer.CharacterAdded:Connect(function()
        task.wait(1)
        if MOVE_CONFIG.isSpeedEnabled then
            stopCFrameSpeed()
            task.wait(0.1)
            startCFrameSpeed()
        end
        if MOVE_CONFIG.isAnimMoveEnabled then
            stopAnimMove()
            task.wait(0.1)
            startAnimMove()
        end
    end)
end

-- ============================================================
-- 主函数
-- ============================================================
local function main()
    print("CFrame加速移动脚本（双模式版）已启动!")

    local elements = createControlPanel()

    elements.speedButton.MouseButton1Click:Connect(function()
        toggleSpeed(elements)
    end)
    elements.speedUpButton.MouseButton1Click:Connect(function()
        adjustSpeed(MOVE_CONFIG.speedStep, elements)
    end)
    elements.speedDownButton.MouseButton1Click:Connect(function()
        adjustSpeed(-MOVE_CONFIG.speedStep, elements)
    end)
    elements.animMoveButton.MouseButton1Click:Connect(function()
        toggleAnimMove(elements)
    end)

    setupCharacterListener()
    updateSpeedLabel(elements)
end

local function cleanup()
    stopCFrameSpeed()
    stopAnimMove()
end

main()
game:BindToClose(cleanup)
