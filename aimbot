local function MakeToggle(label, getter, setter)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,0,0,36); f.BackgroundColor3 = Color3.fromRGB(25,25,35)
    f.BorderSizePixel = 0; f.ZIndex = 12
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,6); c.Parent = f end
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1,-60,1,0); lbl.Position = UDim2.new(0,10,0,0)
    lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.fromRGB(200,200,220)
    lbl.Font = Enum.Font.Gotham; lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.Text = label; lbl.ZIndex = 13; lbl.Parent = f
    local track = Instance.new("Frame")
    track.Size = UDim2.new(0,40,0,20); track.Position = UDim2.new(1,-50,0.5,-10)
    track.BackgroundColor3 = getter() and Color3.fromRGB(80,200,120) or Color3.fromRGB(60,60,80)
    track.BorderSizePixel = 0; track.ZIndex = 13; track.Parent = f
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(1,0); c.Parent = track end
    local thumb = Instance.new("Frame")
    thumb.Size = UDim2.new(0,16,0,16)
    thumb.Position = getter() and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)
    thumb.BackgroundColor3 = Color3.fromRGB(240,240,255); thumb.BorderSizePixel = 0
    thumb.ZIndex = 14; thumb.Parent = track
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(1,0); c.Parent = thumb end
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,0,1,0); btn.BackgroundTransparency = 1
    btn.Text = ""; btn.ZIndex = 15; btn.Parent = f
    btn.MouseButton1Click:Connect(function()
        local v = not getter(); setter(v)
        TweenService:Create(track, TweenInfo.new(0.15), {
            BackgroundColor3 = v and Color3.fromRGB(80,200,120) or Color3.fromRGB(60,60,80)
        }):Play()
        TweenService:Create(thumb, TweenInfo.new(0.15), {
            Position = v and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)
        }):Play()
    end)
    f.Parent = Content; return f
end

local function MakeSlider(label, min, max, step, getter, setter)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,0,0,56); f.BackgroundColor3 = Color3.fromRGB(25,25,35)
    f.BorderSizePixel = 0; f.ZIndex = 12
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,6); c.Parent = f end
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1,-60,0,24); lbl.Position = UDim2.new(0,10,0,4)
    lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.fromRGB(200,200,220)
    lbl.Font = Enum.Font.Gotham; lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.Text = label; lbl.ZIndex = 13; lbl.Parent = f
    local valLbl = Instance.new("TextLabel")
    valLbl.Size = UDim2.new(0,52,0,24); valLbl.Position = UDim2.new(1,-58,0,4)
    valLbl.BackgroundTransparency = 1; valLbl.TextColor3 = Color3.fromRGB(100,200,255)
    valLbl.Font = Enum.Font.GothamBold; valLbl.TextSize = 13
    valLbl.TextXAlignment = Enum.TextXAlignment.Right
    valLbl.Text = tostring(getter()); valLbl.ZIndex = 13; valLbl.Parent = f
    local trackBg = Instance.new("Frame")
    trackBg.Size = UDim2.new(1,-20,0,6); trackBg.Position = UDim2.new(0,10,1,-18)
    trackBg.BackgroundColor3 = Color3.fromRGB(50,50,70); trackBg.BorderSizePixel = 0
    trackBg.ZIndex = 13; trackBg.Parent = f
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(1,0); c.Parent = trackBg end
    local r0 = (getter()-min)/(max-min)
    local trackFill = Instance.new("Frame")
    trackFill.Size = UDim2.new(r0,0,1,0); trackFill.BackgroundColor3 = Color3.fromRGB(100,160,255)
    trackFill.BorderSizePixel = 0; trackFill.ZIndex = 14; trackFill.Parent = trackBg
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(1,0); c.Parent = trackFill end
    local thumb = Instance.new("Frame")
    thumb.Size = UDim2.new(0,16,0,16); thumb.AnchorPoint = Vector2.new(0.5,0.5)
    thumb.Position = UDim2.new(r0,0,0.5,0)
    thumb.BackgroundColor3 = Color3.fromRGB(200,220,255); thumb.BorderSizePixel = 0
    thumb.ZIndex = 15; thumb.Parent = trackBg
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(1,0); c.Parent = thumb end
    local dragging = false
    local function updateFromX(absX)
        local r = math.clamp((absX - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
        local v = math.clamp(math.round((min + (max-min)*r) / step) * step, min, max)
        setter(v); valLbl.Text = tostring(v)
        local rr = (v-min)/(max-min)
        trackFill.Size = UDim2.new(rr,0,1,0); thumb.Position = UDim2.new(rr,0,0.5,0)
    end
    local hitBtn = Instance.new("TextButton")
    hitBtn.Size = UDim2.new(1,0,0,24); hitBtn.Position = UDim2.new(0,0,1,-24)
    hitBtn.BackgroundTransparency = 1; hitBtn.Text = ""; hitBtn.ZIndex = 16; hitBtn.Parent = f
    hitBtn.MouseButton1Down:Connect(function(x) dragging=true; updateFromX(x) end)
    hitBtn.TouchStarted:Connect(function(touch) dragging=true; updateFromX(touch.Position.X) end)
    hitBtn.TouchMoved:Connect(function(touch) if dragging then updateFromX(touch.Position.X) end end)
    hitBtn.TouchEnded:Connect(function() dragging=false end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging and (inp.UserInputType == Enum.UserInputType.MouseMovement
            or inp.UserInputType == Enum.UserInputType.Touch) then
            updateFromX(inp.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
            or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    f.Parent = Content; return f
end

local function MakeModeSelector()
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,0,0,50); f.BackgroundColor3 = Color3.fromRGB(25,25,35)
    f.BorderSizePixel = 0; f.ZIndex = 12
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,6); c.Parent = f end
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1,0,0,22); lbl.Position = UDim2.new(0,10,0,4)
    lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.fromRGB(200,200,220)
    lbl.Font = Enum.Font.Gotham; lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.Text = "锁定模式"; lbl.ZIndex = 13; lbl.Parent = f
    local btnT = Instance.new("TextButton")
    btnT.Size = UDim2.new(0,96,0,22); btnT.Position = UDim2.new(0,10,1,-28)
    btnT.Font = Enum.Font.GothamBold; btnT.TextSize = 12; btnT.Text = "点击 Toggle"
    btnT.BorderSizePixel = 0; btnT.ZIndex = 13; btnT.Parent = f
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,5); c.Parent = btnT end
    local btnH = Instance.new("TextButton")
    btnH.Size = UDim2.new(0,96,0,22); btnH.Position = UDim2.new(0,114,1,-28)
    btnH.Font = Enum.Font.GothamBold; btnH.TextSize = 12; btnH.Text = "按住 Hold"
    btnH.BorderSizePixel = 0; btnH.ZIndex = 13; btnH.Parent = f
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,5); c.Parent = btnH end
    local function refresh()
        local t = Config.MobileLockMode == "Toggle"
        btnT.BackgroundColor3 = t and Color3.fromRGB(60,120,200) or Color3.fromRGB(50,50,70)
        btnT.TextColor3 = t and Color3.fromRGB(240,240,255) or Color3.fromRGB(150,150,180)
        btnH.BackgroundColor3 = not t and Color3.fromRGB(60,120,200) or Color3.fromRGB(50,50,70)
        btnH.TextColor3 = not t and Color3.fromRGB(240,240,255) or Color3.fromRGB(150,150,180)
    end
    refresh()
    btnT.MouseButton1Click:Connect(function()
        Config.MobileLockMode = "Toggle"; mobileLockHeld = false; mobileLockToggled = false
        if MobileLockBtnLabel then MobileLockBtnLabel.Text = "🎯\nLOCK" end
        if MobileLockBtn then
            TweenService:Create(MobileLockBtn, TweenInfo.new(0.1), {BackgroundColor3=Color3.fromRGB(20,20,30)}):Play()
        end
        if MobileBtnStroke then MobileBtnStroke.Color = Config.CircleColor end
        refresh()
    end)
    btnH.MouseButton1Click:Connect(function()
        Config.MobileLockMode = "Hold"; mobileLockHeld = false; mobileLockToggled = false
        if MobileLockBtnLabel then MobileLockBtnLabel.Text = "🎯\nLOCK" end
        if MobileLockBtn then
            TweenService:Create(MobileLockBtn, TweenInfo.new(0.1), {BackgroundColor3=Color3.fromRGB(20,20,30)}):Play()
        end
        if MobileBtnStroke then MobileBtnStroke.Color = Config.CircleColor end
        refresh()
    end)
    f.Parent = Content; return f
end

