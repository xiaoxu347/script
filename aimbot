-- ============================================================
--  核心逻辑
-- ============================================================
local function GetRootPart(player)
    if player == LocalPlayer then return nil end
    local ch = player.Character
    if not ch then return nil end
    return ch:FindFirstChild("HumanoidRootPart") or ch:FindFirstChild("Torso")
end

local function IsTeammate(player)
    if not Config.TeamCheck then return false end
    return player.Team ~= nil and player.Team == LocalPlayer.Team
end

local function W2S(worldPos)
    local sp, on = Camera:WorldToViewportPoint(worldPos)
    return Vector2.new(sp.X, sp.Y), on, sp.Z
end

local function ScreenCenter()
    return Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
end

local function FindClosestInCircle()
    local center = ScreenCenter()
    local best, bestDist = nil, math.huge
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl == LocalPlayer or IsTeammate(pl) then continue end
        local root = GetRootPart(pl)
        if not root then continue end
        local myChar = LocalPlayer.Character
        if myChar and myChar:FindFirstChild("HumanoidRootPart") then
            if (root.Position - myChar.HumanoidRootPart.Position).Magnitude > Config.MaxDistance then continue end
        end
        local sp, on, depth = W2S(root.Position)
        if not on or depth <= 0 then continue end
        local dist = (sp - center).Magnitude
        if dist <= Config.CircleRadius and dist < bestDist then
            bestDist = dist; best = pl
        end
    end
    return best
end

-- ============================================================
--  摄像机模式管理
--  手机端 Roblox 默认摄像机类型为 Custom，每帧会覆盖 CFrame。
--  锁定时切换为 Scriptable，释放后还原，避免被引擎重置。
-- ============================================================
local originalCamType = Camera.CameraType   -- 保存原始类型（通常是 Custom）
local camTakenOver    = false               -- 是否已接管摄像机

local function TakeoverCamera()
    if not camTakenOver then
        originalCamType = Camera.CameraType
        Camera.CameraType = Enum.CameraType.Scriptable
        camTakenOver = true
    end
end

local function ReleaseCamera()
    if camTakenOver then
        Camera.CameraType = originalCamType
        camTakenOver = false
    end
end

-- 角色重生时重置
LocalPlayer.CharacterAdded:Connect(function()
    camTakenOver = false
    -- 稍等摄像机初始化完毕再记录原始类型
    task.wait(0.5)
    originalCamType = Camera.CameraType
end)

-- ============================================================
--  主循环
-- ============================================================
local lockedTarget = nil

RunService.RenderStepped:Connect(function()
    -- 判断激活状态
    local wantLock = false
    if IsMobile then
        wantLock = (Config.MobileLockMode == "Toggle" and mobileLockToggled)
               or  (Config.MobileLockMode == "Hold"   and mobileLockHeld)
    else
        wantLock = UserInputService:IsKeyDown(Config.LockKey)
    end

    -- 总开关关闭：还原摄像机并清空状态
    if not Config.Enabled then
        ReleaseCamera()
        lockedTarget = nil
        CircleStroke.Color = Config.CircleColor
        CrossH.BackgroundColor3 = Config.CircleColor
        CrossV.BackgroundColor3 = Config.CircleColor
        LockLabel.Text = ""
        return
    end

    local target = FindClosestInCircle()

    if wantLock and target then
        lockedTarget = target
    elseif not wantLock then
        lockedTarget = nil
    end

    -- 目标跑出圆圈则释放
    if lockedTarget then
        local root = GetRootPart(lockedTarget)
        if root then
            local sp, on = W2S(root.Position)
            if not on or (sp - ScreenCenter()).Magnitude > Config.CircleRadius * 1.5 then
                lockedTarget = nil
            end
        else
            lockedTarget = nil
        end
    end

    -- 平滑跟随
    if lockedTarget then
        -- 接管摄像机（手机端关键步骤）
        TakeoverCamera()

        local root = GetRootPart(lockedTarget)
        if root then
            local head = lockedTarget.Character and lockedTarget.Character:FindFirstChild("Head")
            local aimPos = head and head.Position or root.Position
            local sp, on = W2S(aimPos)
            if on then
                local center = ScreenCenter()
                local delta = Vector2.new(sp.X-center.X, sp.Y-center.Y) * Config.SmoothFactor
                local cf = Camera.CFrame
                Camera.CFrame = CFrame.new(cf.Position,
                    cf.LookVector*500 + cf.RightVector*delta.X - cf.UpVector*delta.Y + cf.Position)
            end
        end

        CircleStroke.Color = Config.LockedColor
        CrossH.BackgroundColor3 = Config.LockedColor
        CrossV.BackgroundColor3 = Config.LockedColor
        LockLabel.Text = "🔒 " .. lockedTarget.Name
        LockLabel.TextColor3 = Config.LockedColor
    else
        -- 没有锁定目标：还原摄像机控制权
        ReleaseCamera()

        CircleStroke.Color = Config.CircleColor
        CrossH.BackgroundColor3 = Config.CircleColor
        CrossV.BackgroundColor3 = Config.CircleColor
        if target then
            local hint = IsMobile and "👆 按锁定按钮" or ("[ "..Config.LockKey.Name.." ] 锁定")
            LockLabel.Text = hint
            LockLabel.TextColor3 = Color3.fromRGB(255, 220, 80)
        else
            LockLabel.Text = ""
        end
    end

    CircleFrame.Visible = Config.ShowCircle and Config.Enabled
end)

print("[AimAssist] 已加载 | 平台: " .. (IsMobile and "手机端 📱" or "PC端 🖥"))
