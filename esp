-- Roblox ESP脚本 - 用于游戏开发测试
-- 显示其他玩家的高亮和用户名

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- ESP配置
local ESPSettings = {
    Enabled = true,
    ShowNames = true,
    ShowDistance = true,
    HighlightColor = Color3.fromRGB(255, 0, 0), -- 红色高亮
    TextColor = Color3.fromRGB(255, 255, 255), -- 白色文字
    FontSize = 14,
    MaxDistance = 1000 -- 最大显示距离
}

-- 存储ESP对象
local ESPObjects = {}

-- 创建BillboardGui用于显示名称
local function createNameTag(player)
    local billboardGui = Instance.new("BillboardGui")
    billboardGui.Name = "ESPTag"
    billboardGui.AlwaysOnTop = true
    billboardGui.Size = UDim2.new(0, 200, 0, 50)
    billboardGui.StudsOffset = Vector3.new(0, 3, 0)
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Name = "NameLabel"
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.TextColor3 = ESPSettings.TextColor
    textLabel.TextStrokeTransparency = 0.5
    textLabel.TextSize = ESPSettings.FontSize
    textLabel.Font = Enum.Font.SourceSansBold
    textLabel.Parent = billboardGui
    
    return billboardGui
end

-- 创建Highlight高亮效果
local function createHighlight(character)
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESPHighlight"
    highlight.FillColor = ESPSettings.HighlightColor
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.OutlineTransparency = 0
    highlight.Parent = character
    
    return highlight
end

-- 为玩家添加ESP
local function addESP(player)
    if player == LocalPlayer then return end
    
    local function characterAdded(character)
        -- 等待角色完全加载
        local humanoidRootPart = character:WaitForChild("HumanoidRootPart", 5)
        local humanoid = character:WaitForChild("Humanoid", 5)
        
        if not humanoidRootPart or not humanoid then return end
        
        -- 创建高亮
        local highlight = createHighlight(character)
        
        -- 创建名称标签
        local nameTag = createNameTag(player)
        nameTag.Adornee = humanoidRootPart
        nameTag.Parent = humanoidRootPart
        
        -- 存储ESP对象
        ESPObjects[player.UserId] = {
            Highlight = highlight,
            NameTag = nameTag,
            Character = character,
            Player = player
        }
        
        -- 更新名称和距离
        local connection
        connection = RunService.RenderStepped:Connect(function()
            if not character.Parent then
                connection:Disconnect()
                return
            end
            
            local camera = workspace.CurrentCamera
            if camera and humanoidRootPart and ESPSettings.Enabled then
                local distance = (camera.CFrame.Position - humanoidRootPart.Position).Magnitude
                
                if distance <= ESPSettings.MaxDistance then
                    local text = player.Name
                    if ESPSettings.ShowDistance then
                        text = text .. "\n[" .. math.floor(distance) .. "m]"
                    end
                    nameTag.NameLabel.Text = text
                    nameTag.Enabled = ESPSettings.ShowNames
                    highlight.Enabled = true
                else
                    nameTag.Enabled = false
                    highlight.Enabled = false
                end
            end
        end)
        
        -- 角色死亡时清理
        humanoid.Died:Connect(function()
            connection:Disconnect()
        end)
    end
    
    -- 当前角色
    if player.Character then
        characterAdded(player.Character)
    end
    
    -- 监听角色重生
    player.CharacterAdded:Connect(characterAdded)
end

-- 移除玩家ESP
local function removeESP(player)
    local espData = ESPObjects[player.UserId]
    if espData then
        if espData.Highlight then espData.Highlight:Destroy() end
        if espData.NameTag then espData.NameTag:Destroy() end
        ESPObjects[player.UserId] = nil
    end
end

-- 为所有现有玩家添加ESP
for _, player in pairs(Players:GetPlayers()) do
    addESP(player)
end

-- 监听新玩家加入
Players.PlayerAdded:Connect(addESP)

-- 监听玩家离开
Players.PlayerRemoving:Connect(removeESP)

-- 切换ESP开关的命令
local function toggleESP()
    ESPSettings.Enabled = not ESPSettings.Enabled
    print("ESP " .. (ESPSettings.Enabled and "已启用" or "已禁用"))
end

-- 在聊天中输入"/esp"来切换ESP
LocalPlayer.Chatted:Connect(function(message)
    if message:lower() == "/esp" then
        toggleESP()
    end
end)

print("ESP脚本已加载！")
print("输入 '/esp' 来切换ESP开关")
print("当前设置:")
print("- 显示名称: " .. tostring(ESPSettings.ShowNames))
print("- 显示距离: " .. tostring(ESPSettings.ShowDistance))
print("- 最大距离: " .. ESPSettings.MaxDistance .. "米")
