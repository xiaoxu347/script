-- 可拖动
local dragging, dragStart, startPos
Title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = Frame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMove then
        local delta = input.Position - dragStart
        Frame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- ============================================
-- ESP 核心逻辑
-- ============================================
local ESPEnabled = true
local ESPData = {}

local function getColor(player)
    if LocalPlayer.Team and player.Team then
        if player.Team == LocalPlayer.Team then
            return Color3.fromRGB(0, 200, 255)   -- 队友蓝
        else
            return Color3.fromRGB(255, 80, 80)    -- 敌人红
        end
    end
    return Color3.fromRGB(255, 215, 0)            -- 默认金色
end

local function addESP(player)
    if player == LocalPlayer then return end

    local function setupCharacter(character)
        task.wait(0.5)  -- 等角色完全加载

        -- 清理旧高亮
        if ESPData[player] then
            pcall(function()
                if ESPData[player].highlight then
                    ESPData[player].highlight:Destroy()
                end
                if ESPData[player].billboard then
                    ESPData[player].billboard:Destroy()
                end
            end)
        end

        local color = getColor(player)

        -- 创建高亮（穿墙透视）
        local hl = Instance.new("Highlight")
        hl.FillColor = color
        hl.OutlineColor = color
        hl.FillTransparency = 0.55
        hl.OutlineTransparency = 0
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Adornee = character
        hl.Parent = character

        -- 创建名字+距离牌
        local root = character:FindFirstChild("HumanoidRootPart")
        local bb, nameL, distL
        if root then
            bb = Instance.new("BillboardGui")
            bb.AlwaysOnTop = true
            bb.Size = UDim2.new(0, 110, 0, 38)
            bb.StudsOffset = Vector3.new(0, 3.2, 0)
            bb.Adornee = root
            bb.Parent = character

            nameL = Instance.new("TextLabel", bb)
            nameL.Size = UDim2.new(1, 0, 0.58, 0)
            nameL.BackgroundTransparency = 1
            nameL.Text = player.DisplayName
            nameL.TextColor3 = color
            nameL.TextStrokeTransparency = 0
            nameL.TextStrokeColor3 = Color3.fromRGB(0,0,0)
            nameL.Font = Enum.Font.GothamBold
            nameL.TextScaled = true

            distL = Instance.new("TextLabel", bb)
            distL.Size = UDim2.new(1, 0, 0.42, 0)
            distL.Position = UDim2.new(0, 0, 0.58, 0)
            distL.BackgroundTransparency = 1
            distL.Text = "?"
            distL.TextColor3 = Color3.fromRGB(220, 220, 220)
            distL.TextStrokeTransparency = 0
            distL.TextStrokeColor3 = Color3.fromRGB(0,0,0)
            distL.Font = Enum.Font.Gotham
            distL.TextScaled = true
        end

        ESPData[player] = {
            highlight = hl,
            billboard = bb,
            distLabel = distL,
            nameLabel = nameL,
        }

        DebugLabel.Text = "已追踪: " .. player.DisplayName
    end

    player.CharacterAdded:Connect(setupCharacter)
    if player.Character then
        setupCharacter(player.Character)
    end
end

local function removeESP(player)
    if ESPData[player] then
        pcall(function()
            if ESPData[player].highlight then ESPData[player].highlight:Destroy() end
            if ESPData[player].billboard then ESPData[player].billboard:Destroy() end
        end)
        ESPData[player] = nil
    end
end

-- 初始化所有玩家
for _, p in ipairs(Players:GetPlayers()) do
    addESP(p)
end
Players.PlayerAdded:Connect(addESP)
Players.PlayerRemoving:Connect(removeESP)

-- ============================================
-- 每帧更新
-- ============================================
RunService.Heartbeat:Connect(function()
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local count = 0

    for player, data in pairs(ESPData) do
        if not player.Parent then
            removeESP(player)
            continue
        end

        local char = player.Character
        local theirRoot = char and char:FindFirstChild("HumanoidRootPart")
        local dist = 0
        if myRoot and theirRoot then
            dist = math.floor((myRoot.Position - theirRoot.Position).Magnitude)
        end

        local visible = ESPEnabled and dist > 0 and dist <= 500
        local color = getColor(player)

        if data.highlight then
            data.highlight.Enabled = visible
            data.highlight.FillColor = color
            data.highlight.OutlineColor = color
        end
        if data.billboard then
            data.billboard.Enabled = visible
        end
        if data.distLabel then
            data.distLabel.Text = dist .. " studs"
        end
        if data.nameLabel then
            data.nameLabel.TextColor3 = color
        end

        if visible then count += 1 end
    end

    CountLabel.Text = "追踪玩家：" .. count
end)

-- ============================================
-- 开关逻辑
-- ============================================
local function toggleESP(state)
    ESPEnabled = state
    ToggleBtn.Text = state and "✅  ESP 开启" or "❌  ESP 关闭"
    ToggleBtn.BackgroundColor3 = state 
        and Color3.fromRGB(0, 170, 100) 
        or Color3.fromRGB(170, 50, 50)
    StatusLabel.Text = state and "状态：✅ 已开启" or "状态：❌ 已关闭"
    StatusLabel.TextColor3 = state 
        and Color3.fromRGB(100, 255, 150) 
        or Color3.fromRGB(255, 100, 100)
end

ToggleBtn.MouseButton1Click:Connect(function()
    toggleESP(not ESPEnabled)
end)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.F then
        toggleESP(not ESPEnabled)
    end
end)

