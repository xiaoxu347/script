    setStatus("⛔ 已停止", Color3.fromRGB(180, 80, 80))
end)

safeOnBtn.MouseButton1Click:Connect(function()
    local found = targetPlayer or resolveTarget()
    if not found then return end
    stopAll()
    targetPlayer  = found
    followEnabled = true
    safeMode      = true
    startSafeMode()
    setStatus("🛡 安全观战: " .. found.Name, Color3.fromRGB(80, 200, 140))
    found.CharacterRemoving:Connect(function()
        if targetPlayer == found and safeMode then
            setStatus("⏳ 目标消失，等待重生...", Color3.fromRGB(200, 160, 60))
        end
    end)
    found.CharacterAdded:Connect(function()
        if targetPlayer == found and safeMode then
            task.wait(0.5)
            startSafeMode()
            setStatus("🛡 安全观战: " .. found.Name, Color3.fromRGB(80, 200, 140))
        end
    end)
end)

safeOffBtn.MouseButton1Click:Connect(function()
    if not followEnabled then
        setStatus("⚠ 未在跟随状态", Color3.fromRGB(255, 180, 60))
        return
    end
    local prev = targetPlayer
    stopAll()
    if prev then
        targetPlayer  = prev
        followEnabled = true
        safeMode      = false
        startFollow()
        setStatus("👻 切回跟随: " .. prev.Name, Color3.fromRGB(160, 100, 255))
    end
end)

