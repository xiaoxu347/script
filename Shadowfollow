    -- 用 inputBox 的 AbsolutePosition + AbsoluteSize 计算
    local absPos  = inputBox.AbsolutePosition
    local absSize = inputBox.AbsoluteSize
    dropFrame.Position = UDim2.new(
        0, absPos.X,
        0, absPos.Y + absSize.Y + 4
    )
    dropFrame.Size = UDim2.new(0, absSize.X, 0, dropFrame.Size.Y.Offset)
end)

-- 构建/刷新下拉列表
local function buildDrop(filter)
    -- 清旧项
    for _, child in ipairs(dropFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    local trimmed = (filter or ""):match("^%s*(.-)%s*$"):lower()
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then
            if trimmed == ""
                or p.Name:lower():find(trimmed, 1, true)
                or p.DisplayName:lower():find(trimmed, 1, true)
            then
                table.insert(list, p)
            end
        end
    end

    if #list == 0 then
        dropFrame.Visible = false
        return
    end

    local ROW_H = 30
    for i, p in ipairs(list) do
        local displayText = p.Name
        if p.DisplayName ~= p.Name then
            displayText = p.Name .. "  (" .. p.DisplayName .. ")"
        end

        local item = Instance.new("TextButton", dropFrame)
        item.Size             = UDim2.new(1, 0, 0, ROW_H)
        item.BackgroundColor3 = Color3.fromRGB(24, 20, 40)
        item.TextColor3       = Color3.fromRGB(210, 190, 255)
        item.Text             = displayText
        item.TextSize         = 12
        item.Font             = Enum.Font.Gotham
        item.BorderSizePixel  = 0
        item.TextXAlignment   = Enum.TextXAlignment.Left
        item.TextTruncate     = Enum.TextTruncate.AtEnd
        item.ZIndex           = 51
        item.LayoutOrder      = i
        do local c = Instance.new("UICorner", item); c.CornerRadius = UDim.new(0, 5) end
        do local pd = Instance.new("UIPadding", item); pd.PaddingLeft = UDim.new(0, 10) end

        item.MouseEnter:Connect(function()
            item.BackgroundColor3 = Color3.fromRGB(55, 38, 90)
        end)
        item.MouseLeave:Connect(function()
            item.BackgroundColor3 = Color3.fromRGB(24, 20, 40)
        end)
        item.MouseButton1Click:Connect(function()
            inputBox.Text     = p.Name
            dropFrame.Visible = false
        end)
    end

    -- 最多显示6行，超出可滚动（Roblox不原生支持滚动，限高即可）
    local maxRows = math.min(#list, 6)
    dropFrame.Size = UDim2.new(
        dropFrame.Size.X.Scale, dropFrame.Size.X.Offset,
        0, maxRows * ROW_H + 8
    )
    dropFrame.Visible = true
end

-- 输入框聚焦 → 展开全部玩家
inputBox.Focused:Connect(function()
    buildDrop(inputBox.Text)
end)

-- 输入内容变化 → 实时过滤
inputBox:GetPropertyChangedSignal("Text"):Connect(function()
    if dropFrame.Visible then
        buildDrop(inputBox.Text)
    end
end)

