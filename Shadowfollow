local function makeBtn(parent, text, color, w)
    local btn = Instance.new("TextButton", parent)
    btn.Size             = UDim2.new(0, w, 1, 0)
    btn.BackgroundColor3 = color
    btn.TextColor3       = Color3.fromRGB(255, 255, 255)
    btn.Text             = text
    btn.TextSize         = 11
    btn.Font             = Enum.Font.GothamBold
    btn.BorderSizePixel  = 0
    do local c = Instance.new("UICorner", btn); c.CornerRadius = UDim.new(0, 8) end
    local orig = color
    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.new(
            math.min(orig.R+.15,1), math.min(orig.G+.15,1), math.min(orig.B+.15,1))
    end)
    btn.MouseLeave:Connect(function() btn.BackgroundColor3 = orig end)
    return btn
end

