-- ══════════════════════════════════════
--  按钮逻辑
-- ══════════════════════════════════════
local function resolveTarget()
    local name = inputBox.Text:match("^%s*(.-)%s*$")
    if name == "" then
        setStatus("⚠ 请选择或输入玩家名称", Color3.fromRGB(255, 180, 60))
        return nil
    end
    local b = tonumber(behindBox.Text); if b then CFG.behindDist  = b end
    local a = tonumber(aboveBox.Text);  if a then CFG.aboveOffset = a end
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower() == name:lower() or p.DisplayName:lower() == name:lower() then
            if p == LP then
                setStatus("❌ 不能跟随自己", Color3.fromRGB(255, 80, 80))
                return nil
            end
            return p
        end
    end
    setStatus("❌ 未找到玩家: " .. name, Color3.fromRGB(255, 80, 80))
    return nil
end

confirmBtn.MouseButton1Click:Connect(function()
    local found = resolveTarget()
    if not found then return end
    stopAll()
    targetPlayer  = found
    followEnabled = true
    safeMode      = false
    startFollow()
    setStatus("👻 跟随中: " .. found.Name, Color3.fromRGB(160, 100, 255))
    found.CharacterRemoving:Connect(function()
        if targetPlayer == found and not safeMode then
            stopAll()
            setStatus("⚠ 目标消失，已停止", Color3.fromRGB(255, 180, 60))
        end
    end)
end)

stopBtn.MouseButton1Click:Connect(function()
