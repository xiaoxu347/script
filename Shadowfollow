-- ══════════════════════════════════════
--  配置
-- ══════════════════════════════════════
local CFG = {
    behindDist   = 4,
    aboveOffset  = 2,
    safeDepth    = -80,
    camDist      = 12,
    camHeight    = 5,
}

-- ══════════════════════════════════════
--  状态
-- ══════════════════════════════════════
local followEnabled = false
local safeMode      = false
local targetPlayer  = nil
local followConn    = nil
local safeModeConn  = nil

local function getRootOf(player)
    local c = player and player.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function getMyParts()
    local c = LP.Character
    return c and c:FindFirstChild("HumanoidRootPart"),
           c and c:FindFirstChild("Humanoid")
end

local function stopAll()
    if followConn   then followConn:Disconnect();   followConn   = nil end
    if safeModeConn then safeModeConn:Disconnect(); safeModeConn = nil end
    local _, myHum = getMyParts()
    if myHum then myHum.PlatformStand = false end
    followEnabled = false
    safeMode      = false
    targetPlayer  = nil
end

local function startFollow()
    if followConn then followConn:Disconnect(); followConn = nil end
    if not targetPlayer then return end
    local myRoot, myHum = getMyParts()
    if not myRoot or not myHum then return end
    myHum.PlatformStand = true
    followConn = RunService.RenderStepped:Connect(function()
        myRoot, myHum = getMyParts()
        if not myRoot or not myHum then return end
        local tRoot = getRootOf(targetPlayer)
        if not tRoot then return end
        local dest = tRoot.CFrame * CFrame.new(0, CFG.aboveOffset, CFG.behindDist)
        myRoot.CFrame                  = dest
        myRoot.AssemblyLinearVelocity  = Vector3.zero
        myRoot.AssemblyAngularVelocity = Vector3.zero
        local myPos   = myRoot.Position
        local tPos    = tRoot.Position
        local lookDir = (tPos - myPos).Unit
        local camPos  = myPos - lookDir * CFG.camDist + Vector3.new(0, CFG.camHeight, 0)
        camera.CFrame = CFrame.lookAt(camPos, tPos)
    end)
end

local function startSafeMode()
    if safeModeConn then safeModeConn:Disconnect(); safeModeConn = nil end
    if followConn   then followConn:Disconnect();   followConn   = nil end
    if not targetPlayer then return end
    local myRoot, myHum = getMyParts()
    if not myRoot or not myHum then return end
    local safePos = Vector3.new(myRoot.Position.X, CFG.safeDepth, myRoot.Position.Z)
    myHum.PlatformStand = true
    myRoot.CFrame       = CFrame.new(safePos)
    myRoot.AssemblyLinearVelocity  = Vector3.zero
    myRoot.AssemblyAngularVelocity = Vector3.zero
    safeModeConn = RunService.RenderStepped:Connect(function()
        myRoot, myHum = getMyParts()
        if myRoot then
            myRoot.CFrame                  = CFrame.new(safePos)
            myRoot.AssemblyLinearVelocity  = Vector3.zero
            myRoot.AssemblyAngularVelocity = Vector3.zero
        end
        local tRoot = getRootOf(targetPlayer)
        if not tRoot then return end
        local tPos   = tRoot.Position
        local camPos = tPos + tRoot.CFrame.LookVector * (-10) + Vector3.new(0, 6, 0)
        camera.CFrame = CFrame.lookAt(camPos, tPos)
    end)
end

LP.CharacterAdded:Connect(function()
    task.wait(0.5)
    if not followEnabled or not targetPlayer then return end
    if safeMode then startSafeMode() else startFollow() end
end)

