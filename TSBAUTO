-- ══════════════════════════════════════
--  工具函数
-- ══════════════════════════════════════
local function stopTracking()
    if trackConn then trackConn:Disconnect(); trackConn = nil end
end

local function stopAttacking()
    isAttacking = false
end

local function fireServer(args)
    local comm = character:FindFirstChild("Communicate")
    if comm then comm:FireServer(unpack(args)) end
end

-- ══════════════════════════════════════
--  战斗动作
-- ══════════════════════════════════════

-- 前冲刺（追击用）
local function performDash()
    fireServer({ { Dash = Enum.KeyCode.W, Key = Enum.KeyCode.Q, Goal = "KeyPress" } })
end

-- 侧闪：同时模拟 D + Q，触发游戏原生向右冲刺
local function performSideDash()
    local now = tick()
    if (now - lastSideDashTime) < CONFIG.sideDashInterval then return end
    lastSideDashTime = now
    task.spawn(function()
        if VIM then
            -- 有VIM权限：模拟真实按键
            VIM:SendKeyEvent(true,  Enum.KeyCode.D, false, game)
            VIM:SendKeyEvent(true,  Enum.KeyCode.Q, false, game)
            task.wait(CONFIG.sideDashDuration)
            VIM:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
            VIM:SendKeyEvent(false, Enum.KeyCode.D, false, game)
        else
            -- 降级：通过FireServer发送向右冲刺
            fireServer({ { Dash = Enum.KeyCode.D, Key = Enum.KeyCode.Q, Goal = "KeyPress" } })
        end
    end)
end

-- 普通攻击 按下 / 松开
local function performNormalAttack()
    fireServer({ { Goal = "LeftClick", Mobile = true } })
end

local function releaseNormalAttack()
    fireServer({ { Goal = "LeftClickRelease", Mobile = true } })
end

-- 普通技能（队列轮换）
local function performSkill(skillName)
    local now = tick()
    if (now - lastSkillTime) < CONFIG.skillCooldown then return end
    local tool = localPlayer.Backpack:FindFirstChild(skillName)
    if tool then
        fireServer({ { Tool = tool, Goal = "Console Move" } })
        lastSkillTime = now
    else
        warn("[AutoBattle] 技能未找到: " .. skillName)
    end
end

-- Prey's Peril 反制技能（独立冷却，不进队列）
local function performPreySkill()
    local now = tick()
    if (now - lastPreyTime) < CONFIG.preySkillCooldown then return end
    local tool = localPlayer.Backpack:FindFirstChild(CONFIG.preySkillName)
    if tool then
        fireServer({ { Tool = tool, Goal = "Console Move" } })
        lastPreyTime = now
        if statusText then
            task.spawn(function()
                statusText.Text      = "⚡ 触发反制: " .. CONFIG.preySkillName
                statusText.TextColor3= Color3.fromRGB(255, 220, 60)
                task.wait(0.8)
                statusText.TextColor3= Color3.fromRGB(120, 220, 160)
            end)
        end
    else
        warn("[AutoBattle] 反制技能未找到: " .. CONFIG.preySkillName)
    end
end

-- 瞬移到目标背后
local function teleportBehindTarget()
    local targetPlayer = Players:FindFirstChild(CONFIG.targetPlayerName)
    if not targetPlayer then return end
    local targetChar = targetPlayer.Character
    if not targetChar then return end
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
    local myRoot     = character:FindFirstChild("HumanoidRootPart")
    if not targetRoot or not myRoot then return end

    -- 站在目标背后（目标LookVector方向 + 距离），面朝目标
    local behind = targetRoot.CFrame.LookVector * CONFIG.teleportBehindDist
    local newPos  = Vector3.new(
        targetRoot.Position.X + behind.X,
        targetRoot.Position.Y,
        targetRoot.Position.Z + behind.Z
    )
    myRoot.CFrame = CFrame.lookAt(newPos, targetRoot.Position)
end

-- 攻击循环（独立协程）
local function attackLoop()
    if isAttacking then return end
    isAttacking = true
    task.spawn(function()
        while isAttacking do
            performNormalAttack()
            task.wait(CONFIG.attackInterval)
            releaseNormalAttack()

            local skillName = CONFIG.skillQueue[currentSkillIdx]
            performSkill(skillName)
            currentSkillIdx = currentSkillIdx % #CONFIG.skillQueue + 1

            task.wait(CONFIG.attackGap)
        end
    end)
end

-- ══════════════════════════════════════
--  追踪主逻辑
-- ══════════════════════════════════════
local function trackAndAim()
    stopTracking()

    local targetPlayer = Players:FindFirstChild(CONFIG.targetPlayerName)
    if not targetPlayer then
        warn("[AutoBattle] 未找到目标: " .. CONFIG.targetPlayerName)
        if statusText then statusText.Text = "状态: ❌ 目标未找到" end
        return
    end

    local targetCharacter = targetPlayer.Character or targetPlayer.CharacterAdded:Wait()
    local targetHumanoid  = targetCharacter:WaitForChild("Humanoid")

    -- 清理所有旧连接
    if targetDiedConn    then targetDiedConn:Disconnect();    targetDiedConn    = nil end
    if targetRespawnConn then targetRespawnConn:Disconnect(); targetRespawnConn = nil end
    if targetRagdollConn then targetRagdollConn:Disconnect(); targetRagdollConn = nil end
    if targetStateConn   then targetStateConn:Disconnect();   targetStateConn   = nil end
    if animWatchConn     then animWatchConn:Disconnect();     animWatchConn     = nil end
    if selfAnimWatchConn then selfAnimWatchConn:Disconnect(); selfAnimWatchConn = nil end
    targetIsRagdoll  = false
    preyAnimDetected = false
    teleportDetected = false

    -- ── 目标死亡 ──
    targetDiedConn = targetHumanoid.Died:Connect(function()
        stopTracking(); stopAttacking()
        targetIsRagdoll = false; preyAnimDetected = false
        if animWatchConn     then animWatchConn:Disconnect();     animWatchConn     = nil end
        if selfAnimWatchConn then selfAnimWatchConn:Disconnect(); selfAnimWatchConn = nil end
        if statusText then statusText.Text = "状态: 💀 目标已死亡" end
    end)

    -- ── 目标重生 ──
    targetRespawnConn = targetPlayer.CharacterAdded:Connect(function(newChar)
        targetCharacter  = newChar
        targetIsRagdoll  = false; preyAnimDetected = false; teleportDetected = false
        if animWatchConn     then animWatchConn:Disconnect();     animWatchConn     = nil end
        if selfAnimWatchConn then selfAnimWatchConn:Disconnect(); selfAnimWatchConn = nil end
        task.wait(0.5)
        trackAndAim()
    end)

    -- ── 布娃娃检测（双保险）──
    targetRagdollConn = targetHumanoid:GetPropertyChangedSignal("PlatformStand"):Connect(function()
        local was = targetIsRagdoll
        targetIsRagdoll = targetHumanoid.PlatformStand
        if not was and targetIsRagdoll then stopAttacking() end
    end)
    targetStateConn = targetHumanoid.StateChanged:Connect(function(_, new)
        if new == Enum.HumanoidStateType.Physics then
            targetIsRagdoll = true; stopAttacking()
        elseif new == Enum.HumanoidStateType.GettingUp
            or new == Enum.HumanoidStateType.Running
            or new == Enum.HumanoidStateType.Landed
            or new == Enum.HumanoidStateType.RunningNoPhysics then
            targetIsRagdoll = false
        end
    end)

    -- ── 目标动画反制检测（Prey's Peril）──
    local targetAnimator = targetHumanoid:FindFirstChildOfClass("Animator")
    if targetAnimator then
        animWatchConn = RunService.Heartbeat:Connect(function()
            if not trackEnabled then return end
            local myRoot  = character:FindFirstChild("HumanoidRootPart")
            local tgtRoot = targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart")
            if not myRoot or not tgtRoot then return end
            if (tgtRoot.Position - myRoot.Position).Magnitude > CONFIG.attackRange then
                preyAnimDetected = false; return
            end
            local found = false
            for _, t in ipairs(targetAnimator:GetPlayingAnimationTracks()) do
                if tostring(t.Animation.AnimationId):find(CONFIG.preyTriggerAnimId) then
                    found = true; break
                end
            end
            if found and not preyAnimDetected then
                preyAnimDetected = true
                performPreySkill()
            elseif not found then
                preyAnimDetected = false
            end
        end)
    else
        warn("[AutoBattle] 目标无 Animator，反制检测未启动")
    end

    -- ── 自身动画瞬移检测 ──
    local selfHumanoid = character:WaitForChild("Humanoid")
    local selfAnimator = selfHumanoid:FindFirstChildOfClass("Animator")
    if selfAnimator then
        selfAnimWatchConn = RunService.Heartbeat:Connect(function()
            if not trackEnabled then return end
            local found = false
            for _, t in ipairs(selfAnimator:GetPlayingAnimationTracks()) do
                if tostring(t.Animation.AnimationId):find(CONFIG.teleportAnimId) then
                    found = true; break
                end
            end
            if found and not teleportDetected then
                teleportDetected = true
                teleportBehindTarget()
            elseif not found then
                teleportDetected = false
            end
        end)
    else
        warn("[AutoBattle] 自身无 Animator，瞬移检测未启动")
    end

    -- ── 主追踪循环 ──
    trackConn = RunService.RenderStepped:Connect(function()
        if not trackEnabled then return end

        local myRoot  = character:FindFirstChild("HumanoidRootPart")
        local tgtRoot = targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart")
        if not myRoot or not tgtRoot then return end

        local myPos = myRoot.Position
        local tgtPos= tgtRoot.Position
        local dist  = (tgtPos - myPos).Magnitude
        local dir   = (tgtPos - myPos).Unit

        -- 镜头对准目标
        camera.CFrame = CFrame.lookAt(camera.CFrame.Position, tgtPos)

        -- ── 布娃娃模式：撤退 ──
        if targetIsRagdoll then
            stopAttacking()
            local fleeDir = -dir
            myRoot.CFrame = CFrame.lookAt(myPos, myPos + fleeDir)
            humanoid:Move(dist < CONFIG.ragdollFleeDistance and fleeDir or Vector3.zero, false)
            if statusText then
                statusText.Text = string.format(
                    "状态: 🪆 目标布娃娃，撤退中\n目标: %s | 距离: %.1fm",
                    CONFIG.targetPlayerName, dist)
            end
            return
        end

        -- ── 正常追踪：用 Humanoid:Move 触发跑步动画 ──
        if dist > CONFIG.minFollowDistance then
            myRoot.CFrame = CFrame.lookAt(myPos, Vector3.new(tgtPos.X, myPos.Y, tgtPos.Z))
            humanoid:Move(dir, false)
        else
            humanoid:Move(Vector3.zero, false)
        end

        -- 冲刺（带debounce）
        local now = tick()
        if dist <= CONFIG.dashRange and (now - lastDashTime) >= CONFIG.dashDebounce then
            performDash(); lastDashTime = now
        end

        -- 攻击 + 侧闪
        if dist <= CONFIG.attackRange then
            attackLoop()
            performSideDash()
        else
            stopAttacking()
        end

        -- 更新状态栏
        if statusText then
            statusText.Text = string.format(
                "状态: 🎯 追踪中\n目标: %s | 距离: %.1fm",
                CONFIG.targetPlayerName, dist)
        end
    end)
end

-- ══════════════════════════════════════
--  本地玩家死亡/重生处理
-- ══════════════════════════════════════
local function onLocalDeath()
    stopTracking(); stopAttacking()
    teleportDetected = false
    if selfAnimWatchConn then selfAnimWatchConn:Disconnect(); selfAnimWatchConn = nil end
    if humanoidDiedConn  then humanoidDiedConn:Disconnect();  humanoidDiedConn  = nil end
    if statusText then statusText.Text = "状态: 💫 重生中..." end

    character = localPlayer.CharacterAdded:Wait()
    humanoid  = character:WaitForChild("Humanoid")
    humanoidDiedConn = humanoid.Died:Connect(onLocalDeath)

    task.wait(1)
    trackAndAim()
end

humanoidDiedConn = humanoid.Died:Connect(onLocalDeath)

