-- ══════════════════════════════════════
--  状态变量
-- ══════════════════════════════════════
-- 模式："guard"=跟随主人  "combat"=战斗
local mode            = "guard"
local currentEnemy    = nil   -- 当前锁定的敌方Player对象
local currentEnemyChar= nil   -- 敌方Character
local isAttacking     = false
local enemyIsRagdoll  = false
local preyDetected    = false
local tpDetected      = false
local trackEnabled    = true

local lastSkillTime   = 0
local lastPreyTime    = 0
local lastDashTime    = 0
local lastSideDash    = 0
local lastThreatCheck = 0
local skillIdx        = 1

-- 连接管理
local CONN = {}
local function disconnectAll()
    for k, c in pairs(CONN) do
        if c then pcall(function() c:Disconnect() end) end
        CONN[k] = nil
    end
end

-- GUI标签（提前声明）
local statusLabel, modeLabel, enemyLabel, ragdollLabel, preyLabel, tpLabel, cdLabel

local function setStatus(text, color)
    if not statusLabel then return end
    statusLabel.Text       = text
    statusLabel.TextColor3 = color or Color3.fromRGB(120, 220, 160)
end

-- ══════════════════════════════════════
--  基础动作
-- ══════════════════════════════════════
local function fireServer(t)
    local comm = character and character:FindFirstChild("Communicate")
    if comm then pcall(function() comm:FireServer(unpack(t)) end) end
end

local function performDash()
    fireServer({ { Dash = Enum.KeyCode.W, Key = Enum.KeyCode.Q, Goal = "KeyPress" } })
end

local function performSideDash()
    local now = tick()
    if now - lastSideDash < CFG.sideDashInterval then return end
    lastSideDash = now
    task.spawn(function()
        if VIM then
            pcall(function()
                VIM:SendKeyEvent(true,  Enum.KeyCode.D, false, game)
                VIM:SendKeyEvent(true,  Enum.KeyCode.Q, false, game)
                task.wait(CFG.sideDashDuration)
                VIM:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
                VIM:SendKeyEvent(false, Enum.KeyCode.D, false, game)
            end)
        else
            fireServer({ { Dash = Enum.KeyCode.D, Key = Enum.KeyCode.Q, Goal = "KeyPress" } })
        end
    end)
end

local function performSkill(name)
    local now = tick()
    if now - lastSkillTime < CFG.skillCD then return end
    local tool = LP.Backpack:FindFirstChild(name)
    if not tool then return end
    fireServer({ { Tool = tool, Goal = "Console Move" } })
    lastSkillTime = now
end

local function performPreySkill()
    local now = tick()
    if now - lastPreyTime < CFG.preyCD then return end
    local tool = LP.Backpack:FindFirstChild(CFG.preySkillName)
    if not tool then return end
    fireServer({ { Tool = tool, Goal = "Console Move" } })
    lastPreyTime = now
    task.spawn(function()
        setStatus("⚡ 反制触发: " .. CFG.preySkillName, Color3.fromRGB(255, 220, 60))
        task.wait(0.8)
        if statusLabel then statusLabel.TextColor3 = Color3.fromRGB(120, 220, 160) end
    end)
end

local function stopAttacking()
    isAttacking = false
end

local function attackLoop()
    if isAttacking then return end
    isAttacking = true
    task.spawn(function()
        while isAttacking do
            fireServer({ { Goal = "LeftClick",        Mobile = true } })
            task.wait(CFG.attackPressTime)
            fireServer({ { Goal = "LeftClickRelease", Mobile = true } })
            performSkill(CFG.skillQueue[skillIdx])
            skillIdx = skillIdx % #CFG.skillQueue + 1
            task.wait(CFG.attackGap)
        end
    end)
end

-- 动画检测辅助
local function animHasId(animator, id)
    local ok, tracks = pcall(function() return animator:GetPlayingAnimationTracks() end)
    if not ok then return false end
    for _, t in ipairs(tracks) do
        if tostring(t.Animation.AnimationId):find(id, 1, true) then return true end
    end
    return false
end

-- 瞬移到当前敌方背后
local function teleportBehindEnemy()
    if not currentEnemyChar then return end
    local eRoot = currentEnemyChar:FindFirstChild("HumanoidRootPart")
    local mRoot = character and character:FindFirstChild("HumanoidRootPart")
    if not eRoot or not mRoot then return end
    local behind = eRoot.Position - eRoot.CFrame.LookVector * CFG.teleportDist
    behind = Vector3.new(behind.X, eRoot.Position.Y, behind.Z)
    pcall(function() mRoot.CFrame = CFrame.lookAt(behind, eRoot.Position) end)
end

-- ══════════════════════════════════════
--  威胁检测：扫描主人附近的其他玩家
--  返回最近的威胁Player，或nil
-- ══════════════════════════════════════
local function findNearestThreat()
    local masterPlayer = Players:FindFirstChild(CFG.masterName)
    if not masterPlayer or not masterPlayer.Character then return nil end
    local masterRoot = masterPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not masterRoot then return nil end

    local nearest, nearestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        -- 跳过自己和主人
        if p ~= LP and p ~= masterPlayer then
            local c = p.Character
            if c then
                local root = c:FindFirstChild("HumanoidRootPart")
                local hum  = c:FindFirstChild("Humanoid")
                if root and hum and hum.Health > 0 then
                    local dist = (root.Position - masterRoot.Position).Magnitude
                    if dist <= CFG.guardRadius and dist < nearestDist then
                        nearest     = p
                        nearestDist = dist
                    end
                end
            end
        end
    end
    return nearest
end

-- ══════════════════════════════════════
--  进入守卫模式
-- ══════════════════════════════════════
local function enterGuardMode()
    if mode == "guard" then return end
    mode         = "guard"
    currentEnemy     = nil
    currentEnemyChar = nil
    enemyIsRagdoll   = false
    preyDetected     = false
    stopAttacking()

    -- 清除敌方相关连接（保留master和自身连接）
    if CONN.enemyDied    then CONN.enemyDied:Disconnect();    CONN.enemyDied    = nil end
    if CONN.enemyRagdoll then CONN.enemyRagdoll:Disconnect(); CONN.enemyRagdoll = nil end
    if CONN.enemyState   then CONN.enemyState:Disconnect();   CONN.enemyState   = nil end
    if CONN.preyAnim     then CONN.preyAnim:Disconnect();     CONN.preyAnim     = nil end
end

-- ══════════════════════════════════════
--  进入战斗模式（锁定新敌方）
-- ══════════════════════════════════════
local function enterCombatMode(enemyPlayer)
    if currentEnemy == enemyPlayer and mode == "combat" then return end
    mode             = "combat"
    currentEnemy     = enemyPlayer
    currentEnemyChar = enemyPlayer.Character
    enemyIsRagdoll   = false
    preyDetected     = false
    stopAttacking()

    -- 清旧敌方连接
    if CONN.enemyDied    then CONN.enemyDied:Disconnect()    end
    if CONN.enemyRagdoll then CONN.enemyRagdoll:Disconnect() end
    if CONN.enemyState   then CONN.enemyState:Disconnect()   end
    if CONN.preyAnim     then CONN.preyAnim:Disconnect()     end

    local eHum = currentEnemyChar and currentEnemyChar:FindFirstChild("Humanoid")
    if not eHum then return end

    -- 敌方死亡 → 回守卫
    CONN.enemyDied = eHum.Died:Connect(function()
        enterGuardMode()
        setStatus("状态: 🛡 目标击败，回守卫", Color3.fromRGB(100, 200, 255))
    end)

    -- 敌方离开（角色被移除）
    CONN.enemyLeft = currentEnemy.CharacterRemoving:Connect(function()
        enterGuardMode()
    end)

    -- 敌方布娃娃检测
    CONN.enemyRagdoll = eHum:GetPropertyChangedSignal("PlatformStand"):Connect(function()
        enemyIsRagdoll = eHum.PlatformStand
        if enemyIsRagdoll then stopAttacking() end
    end)
    CONN.enemyState = eHum.StateChanged:Connect(function(_, new)
        if new == Enum.HumanoidStateType.Physics then
            enemyIsRagdoll = true; stopAttacking()
        elseif new == Enum.HumanoidStateType.GettingUp
            or new == Enum.HumanoidStateType.Running
            or new == Enum.HumanoidStateType.Landed
            or new == Enum.HumanoidStateType.RunningNoPhysics then
            enemyIsRagdoll = false
        end
    end)

    -- 敌方动画反制（Prey's Peril）
    local eAnimator = eHum:FindFirstChildOfClass("Animator")
    if eAnimator then
        CONN.preyAnim = RunService.Heartbeat:Connect(function()
            if mode ~= "combat" or not trackEnabled then return end
            local mRoot = character  and character:FindFirstChild("HumanoidRootPart")
            local eRoot = currentEnemyChar and currentEnemyChar:FindFirstChild("HumanoidRootPart")
            if not mRoot or not eRoot then return end
            if (eRoot.Position - mRoot.Position).Magnitude > CFG.attackRange then
                preyDetected = false; return
            end
            local found = animHasId(eAnimator, CFG.preyAnimId)
            if found and not preyDetected then
                preyDetected = true; performPreySkill()
            elseif not found then
                preyDetected = false
            end
        end)
    end
end

-- ══════════════════════════════════════
--  主循环
-- ══════════════════════════════════════
local guardAndCombat  -- 前向声明

guardAndCombat = function()
    disconnectAll()
    stopAttacking()
    mode             = "guard"
    currentEnemy     = nil
    currentEnemyChar = nil
    enemyIsRagdoll   = false
    preyDetected     = false
    tpDetected       = false

    local masterPlayer = Players:FindFirstChild(CFG.masterName)
    if not masterPlayer then
        warn("[AutoBattle] 未找到主人: " .. CFG.masterName)
        setStatus("状态: ❌ 主人未找到", Color3.fromRGB(255, 80, 80))
        return
    end

    local masterChar     = masterPlayer.Character or masterPlayer.CharacterAdded:Wait()
    local masterHumanoid = masterChar:WaitForChild("Humanoid")

    -- 主人死亡
    CONN.masterDied = masterHumanoid.Died:Connect(function()
        disconnectAll(); stopAttacking()
        setStatus("状态: 💀 主人死亡", Color3.fromRGB(200, 80, 80))
    end)

    -- 主人重生
    CONN.masterRespawn = masterPlayer.CharacterAdded:Connect(function(newChar)
        masterChar = newChar
        task.wait(0.5)
        guardAndCombat()
    end)

    -- 自身动画瞬移检测（始终运行，瞬移目标根据当前模式）
    local sAnimator = humanoid and humanoid:FindFirstChildOfClass("Animator")
    if sAnimator then
        CONN.tpAnim = RunService.Heartbeat:Connect(function()
            if not trackEnabled then return end
            -- 只在战斗模式且有敌方时才瞬移
            if mode ~= "combat" or not currentEnemyChar then
                tpDetected = false; return
            end
            local found = animHasId(sAnimator, CFG.teleportAnimId)
            if found and not tpDetected then
                tpDetected = true; teleportBehindEnemy()
            elseif not found then
                tpDetected = false
            end
        end)
    end

    -- 主循环
    CONN.main = RunService.RenderStepped:Connect(function()
        if not trackEnabled then return end

        local mRoot = character  and character:FindFirstChild("HumanoidRootPart")
        if not mRoot then return end

        local now = tick()

        -- ── 定期扫描威胁 ──
        if now - lastThreatCheck >= CFG.threatCheckRate then
            lastThreatCheck = now
            local threat = findNearestThreat()
            if threat then
                -- 有威胁 → 进入或更新战斗模式
                if mode == "guard" or currentEnemy ~= threat then
                    enterCombatMode(threat)
                end
                -- 更新敌方char引用（对方可能刚重生）
                currentEnemyChar = threat.Character
            else
                -- 无威胁 → 守卫模式
                if mode == "combat" then enterGuardMode() end
            end
        end

        -- ════════════════════════════
        --  守卫模式：跟随主人，不攻击
        -- ════════════════════════════
        if mode == "guard" then
            local masterRoot = masterChar and masterChar:FindFirstChild("HumanoidRootPart")
            if not masterRoot then return end

            local dist = (masterRoot.Position - mRoot.Position).Magnitude
            local dir  = (masterRoot.Position - mRoot.Position).Unit

            camera.CFrame = CFrame.lookAt(camera.CFrame.Position, masterRoot.Position)

            if dist > CFG.masterFollowDist then
                pcall(function()
                    mRoot.CFrame = CFrame.lookAt(mRoot.Position,
                        Vector3.new(masterRoot.Position.X, mRoot.Position.Y, masterRoot.Position.Z))
                end)
                humanoid:Move(dir, false)
            else
                humanoid:Move(Vector3.zero, false)
            end

            if dist <= CFG.masterDashRange and now - lastDashTime >= CFG.dashDebounce then
                performDash(); lastDashTime = now
            end

            setStatus(string.format(
                "状态: 🛡 守卫模式\n主人: %s | %.1fm",
                CFG.masterName, dist), Color3.fromRGB(100, 200, 255))

        -- ════════════════════════════
        --  战斗模式：追击锁定的敌方
        -- ════════════════════════════
        elseif mode == "combat" then
            if not currentEnemyChar then return end
            local eRoot = currentEnemyChar:FindFirstChild("HumanoidRootPart")
            if not eRoot then return end

            local eDist = (eRoot.Position - mRoot.Position).Magnitude
            local eDir  = (eRoot.Position - mRoot.Position).Unit

            camera.CFrame = CFrame.lookAt(camera.CFrame.Position, eRoot.Position)

            -- 敌方布娃娃：撤退
            if enemyIsRagdoll then
                stopAttacking()
                local fleeDir = -eDir
                pcall(function()
                    mRoot.CFrame = CFrame.lookAt(mRoot.Position, mRoot.Position + fleeDir)
                end)
                humanoid:Move(eDist < CFG.fleeDist and fleeDir or Vector3.zero, false)
                setStatus(string.format(
                    "状态: ⚔ 战斗中\n敌方: %s | %.1fm | 布娃娃↩",
                    currentEnemy.Name, eDist), Color3.fromRGB(255, 180, 50))
                return
            end

            -- 追击敌方
            if eDist > CFG.combatFollowDist then
                pcall(function()
                    mRoot.CFrame = CFrame.lookAt(mRoot.Position,
                        Vector3.new(eRoot.Position.X, mRoot.Position.Y, eRoot.Position.Z))
                end)
                humanoid:Move(eDir, false)
            else
                humanoid:Move(Vector3.zero, false)
            end

            -- 冲刺
            if eDist <= CFG.combatDashRange and now - lastDashTime >= CFG.dashDebounce then
                performDash(); lastDashTime = now
            end

            -- 攻击 + 侧闪
            if eDist <= CFG.attackRange then
                attackLoop()
                performSideDash()
            else
                stopAttacking()
            end

            setStatus(string.format(
                "状态: ⚔ 战斗中\n敌方: %s | %.1fm",
                currentEnemy.Name, eDist), Color3.fromRGB(255, 120, 80))
        end
    end)
end

-- ══════════════════════════════════════
--  本地死亡/重生
-- ══════════════════════════════════════
local function onLocalDeath()
    disconnectAll(); stopAttacking()
    setStatus("状态: 💫 重生中...", Color3.fromRGB(160, 160, 160))

    character = LP.CharacterAdded:Wait()
    humanoid  = character:WaitForChild("Humanoid")
    CONN.localDied = humanoid.Died:Connect(onLocalDeath)

    task.wait(1)
    guardAndCombat()
end

