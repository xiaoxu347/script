-- ══════════════════════════════════════
--  工具函数
-- ══════════════════════════════════════
local function stopTracking()
    if trackConn then
        trackConn:Disconnect()
        trackConn = nil
    end
end

local function stopAttacking()
    isAttacking = false
end

-- ══════════════════════════════════════
--  战斗动作
-- ══════════════════════════════════════
local statusText = nil  -- 供GUI和战斗函数更新

local function fireServer(args)
    local comm = character:FindFirstChild("Communicate")
    if comm then
        comm:FireServer(unpack(args))
    end
end

local function performDash()
    fireServer({ { Dash = Enum.KeyCode.W, Key = Enum.KeyCode.Q, Goal = "KeyPress" } })
end

-- 侧闪：模拟真实D键按下 + Q冲刺键，触发游戏原生向右冲刺
local function performSideDash()
    local now = tick()
    if (now - lastSideDashTime) < CONFIG.sideDashInterval then return end
    lastSideDashTime = now

    task.spawn(function()
        -- 同时按下 D + Q，触发游戏的向右冲刺
        VIM:SendKeyEvent(true,  Enum.KeyCode.D, false, game)
        VIM:SendKeyEvent(true,  Enum.KeyCode.Q, false, game)
        task.wait(CONFIG.sideDashDuration)
        VIM:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
        VIM:SendKeyEvent(false, Enum.KeyCode.D, false, game)
    end)
end

-- Prey's Peril 独立触发（不走普通技能队列，有独立冷却）
local function performPreySkill()
    local now = tick()
    if (now - lastPreyTime) < CONFIG.preySkillCooldown then return end
    local tool = localPlayer.Backpack:FindFirstChild(CONFIG.preySkillName)
    if tool then
        fireServer({ { Tool = tool, Goal = "Console Move" } })
        lastPreyTime = now
        if statusText then
            -- 短暂显示反制提示（下一帧状态更新会覆盖）
            task.spawn(function()
                local prev = statusText.Text
                statusText.Text = "⚡ 触发反制: " .. CONFIG.preySkillName
                statusText.TextColor3 = Color3.fromRGB(255, 220, 60)
                task.wait(0.8)
                statusText.TextColor3 = Color3.fromRGB(120, 220, 160)
            end)
        end
    else
        warn("[AutoBattle] 反制技能未找到: " .. CONFIG.preySkillName)
    end
end

-- 瞬移到目标背后（检测到自身动画 7807831448 时触发）
local function teleportBehindTarget()
    local targetPlayer = Players:FindFirstChild(CONFIG.targetPlayerName)
    if not targetPlayer then return end
    local targetChar = targetPlayer.Character
    if not targetChar then return end
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
    local myRoot     = character:FindFirstChild("HumanoidRootPart")
    if not targetRoot or not myRoot then return end

    -- 目标背后方向 = 目标朝向的反方向
    local behindDir  = targetRoot.CFrame.LookVector  -- 目标面朝方向，我们站背后
    local behindPos  = targetRoot.Position + behindDir * CONFIG.teleportBehindDist

    -- 保持与目标相同高度，朝向目标
    local newCFrame = CFrame.new(
        Vector3.new(behindPos.X, targetRoot.Position.Y, behindPos.Z)
    ) * CFrame.Angles(0, math.pi, 0)  -- 旋转180°朝向目标

    myRoot.CFrame = newCFrame
end
    fireServer({ { Goal = "LeftClick", Mobile = true } })
end

local function releaseNormalAttack()
    fireServer({ { Goal = "LeftClickRelease", Mobile = true } })
end

local function performSkill(skillName)
    local now = tick()
    if (now - lastSkillTime) < CONFIG.skillCooldown then return end
    local tool = localPlayer.Backpack:FindFirstChild(skillName)
    if tool then
        fireServer({ { Tool = tool, Goal = "Console Move" } })
        lastSkillTime = now
    else
        warn("[AutoBattle] 技能未找到: " .. skillName)
    end
end

local function attackLoop()
    if isAttacking then return end
    isAttacking = true
    task.spawn(function()
        while isAttacking do
            performNormalAttack()
            task.wait(CONFIG.attackInterval)
            releaseNormalAttack()

            local skillName = CONFIG.skillQueue[currentSkillIdx]
            performSkill(skillName)
            currentSkillIdx = currentSkillIdx % #CONFIG.skillQueue + 1

            task.wait(CONFIG.attackGap)
        end
    end)
end

-- ══════════════════════════════════════
--  追踪主逻辑
-- ══════════════════════════════════════
local function trackAndAim()
    stopTracking()  -- 防止重复连接

    local targetPlayer = Players:FindFirstChild(CONFIG.targetPlayerName)
    if not targetPlayer then
        warn("[AutoBattle] 未找到目标: " .. CONFIG.targetPlayerName)
        if statusText then statusText.Text = "状态: 目标未找到" end
        return
    end

    local targetCharacter = targetPlayer.Character or targetPlayer.CharacterAdded:Wait()
    local targetHumanoid  = targetCharacter:WaitForChild("Humanoid")

    -- 清理旧连接（包括布娃娃检测）
    if targetDiedConn    then targetDiedConn:Disconnect()    end
    if targetRespawnConn then targetRespawnConn:Disconnect() end
    if targetRagdollConn then targetRagdollConn:Disconnect() end
    if targetStateConn   then targetStateConn:Disconnect()   end
    if selfAnimWatchConn then selfAnimWatchConn:Disconnect(); selfAnimWatchConn = nil end
    targetIsRagdoll = false

    targetDiedConn = targetHumanoid.Died:Connect(function()
        stopTracking()
        stopAttacking()
        targetIsRagdoll = false
        preyAnimDetected = false
        if animWatchConn then animWatchConn:Disconnect(); animWatchConn = nil end
        if statusText then statusText.Text = "状态: 目标已死亡" end
    end)

    -- ── Prey's Peril 动画反制检测 ──
    -- 每帧轮询目标 Animator 正在播放的动画，检测到指定ID立即反制
    if animWatchConn then animWatchConn:Disconnect() end
    local targetAnimator = targetHumanoid:FindFirstChildOfClass("Animator")
    if targetAnimator then
        animWatchConn = RunService.Heartbeat:Connect(function()
            if not trackEnabled then return end
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            local targetRoot = targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart")
            if not rootPart or not targetRoot then return end
            local distance = (targetRoot.Position - rootPart.Position).Magnitude
            if distance > CONFIG.attackRange then
                preyAnimDetected = false
                return
            end

            local detected = false
            for _, track in ipairs(targetAnimator:GetPlayingAnimationTracks()) do
                local animId = tostring(track.Animation.AnimationId)
                if animId:find(CONFIG.preyTriggerAnimId) then
                    detected = true
                    break
                end
            end

            if detected and not preyAnimDetected then
                -- 首次检测到该动画，立即触发反制
                preyAnimDetected = true
                performPreySkill()
            elseif not detected then
                preyAnimDetected = false  -- 动画结束，重置标记，下次可再触发
            end
        end)
    else
        warn("[AutoBattle] 目标没有 Animator，动画反制无法启动")
    end

    -- ── 目标布娃娃检测（绑定在目标身上）──
    -- 方法1: PlatformStand —— 大多数布娃娃系统设置此属性为 true
    targetRagdollConn = targetHumanoid:GetPropertyChangedSignal("PlatformStand"):Connect(function()
        local wasRagdoll = targetIsRagdoll
        targetIsRagdoll = targetHumanoid.PlatformStand
        if not wasRagdoll and targetIsRagdoll then
            stopAttacking()  -- 目标刚倒下，立即停止攻击
        end
    end)
    -- 方法2: HumanoidStateType.Physics —— 另一种布娃娃实现方式
    targetStateConn = targetHumanoid.StateChanged:Connect(function(_, newState)
        if newState == Enum.HumanoidStateType.Physics then
            if not targetIsRagdoll then
                targetIsRagdoll = true
                stopAttacking()
            end
        elseif newState == Enum.HumanoidStateType.GettingUp
            or  newState == Enum.HumanoidStateType.Running
            or  newState == Enum.HumanoidStateType.Landed
            or  newState == Enum.HumanoidStateType.RunningNoPhysics then
            targetIsRagdoll = false  -- 目标已恢复站立，下一帧自动继续追击
        end
    end)

    targetRespawnConn = targetPlayer.CharacterAdded:Connect(function(newChar)
        targetCharacter = newChar
        targetIsRagdoll = false
        preyAnimDetected = false
        teleportDetected = false
        if animWatchConn then animWatchConn:Disconnect(); animWatchConn = nil end
        if selfAnimWatchConn then selfAnimWatchConn:Disconnect(); selfAnimWatchConn = nil end
        task.wait(0.5)
        trackAndAim()
    end)

    -- ── 自身动画瞬移检测 ──
    -- 监听自己的 Animator，检测到指定动画立刻瞬移到目标背后
    local selfHumanoid = character:WaitForChild("Humanoid")
    local selfAnimator = selfHumanoid:FindFirstChildOfClass("Animator")
    if selfAnimator then
        selfAnimWatchConn = RunService.Heartbeat:Connect(function()
            if not trackEnabled then return end
            local detected = false
            for _, track in ipairs(selfAnimator:GetPlayingAnimationTracks()) do
                local animId = tostring(track.Animation.AnimationId)
                if animId:find(CONFIG.teleportAnimId) then
                    detected = true
                    break
                end
            end
            if detected and not teleportDetected then
                teleportDetected = true
                teleportBehindTarget()
            elseif not detected then
                teleportDetected = false
            end
        end)
    else
        warn("[AutoBattle] 自身没有 Animator，瞬移检测无法启动")
    end

    trackConn = RunService.RenderStepped:Connect(function()
        if not trackEnabled then return end

        local rootPart = character:FindFirstChild("HumanoidRootPart")
        local targetRoot = targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart")
        if not rootPart or not targetRoot then return end

        local myPos     = rootPart.Position
        local targetPos = targetRoot.Position
        local distance  = (targetPos - myPos).Magnitude
        local direction = (targetPos - myPos).Unit

        -- 镜头对准
        camera.CFrame = CFrame.lookAt(camera.CFrame.Position, targetPos)

        -- ── 布娃娃模式：远离目标 ──
        if targetIsRagdoll then
            stopAttacking()

            -- 先把角色朝向远离方向，再用 Humanoid:Move 触发跑步动画
            local fleeDir = -direction  -- 反方向
            rootPart.CFrame = CFrame.lookAt(myPos, myPos + fleeDir)

            if distance < CONFIG.ragdollFleeDistance then
                -- 还没拉开足够距离，继续逃
                humanoid:Move(fleeDir, false)  -- false = 世界坐标方向
            else
                -- 已经足够远，原地等待
                humanoid:Move(Vector3.zero, false)
            end

            if statusText then
                statusText.Text = string.format(
                    "状态: 🪆 目标布娃娃，撤退中\n目标: %s\n距离: %.1f m",
                    CONFIG.targetPlayerName, distance
                )
            end
            return  -- 布娃娃期间跳过追击逻辑
        end

        -- ── 正常追踪模式 ──
        -- 朝目标方向旋转角色，再用 Humanoid:Move 触发跑步动画（不用MoveTo）
        if distance > CONFIG.minFollowDistance then
            rootPart.CFrame = CFrame.lookAt(myPos, Vector3.new(targetPos.X, myPos.Y, targetPos.Z))
            humanoid:Move(direction, false)
        else
            humanoid:Move(Vector3.zero, false)
        end

        -- 冲刺（加debounce）
        local now = tick()
        if distance <= CONFIG.dashRange and (now - lastDashTime) >= CONFIG.dashDebounce then
            performDash()
            lastDashTime = now
        end

        -- 攻击 + 侧闪
        if distance <= CONFIG.attackRange then
            attackLoop()
            performSideDash()  -- 在攻击范围内周期性侧闪
        else
            stopAttacking()
        end

        -- 更新GUI状态
        if statusText then
            statusText.Text = string.format(
                "状态: 🎯 追踪中\n目标: %s\n距离: %.1f m",
                CONFIG.targetPlayerName, distance
            )
        end
    end)
end

-- ══════════════════════════════════════
--  死亡/重生处理
-- ══════════════════════════════════════
local function onLocalDeath()
    stopTracking()
    stopAttacking()
    teleportDetected = false
    if selfAnimWatchConn then selfAnimWatchConn:Disconnect(); selfAnimWatchConn = nil end
    if humanoidDiedConn then humanoidDiedConn:Disconnect() end
    if statusText then statusText.Text = "状态: 重生中..." end

    character = localPlayer.CharacterAdded:Wait()
    humanoid  = character:WaitForChild("Humanoid")
    humanoidDiedConn = humanoid.Died:Connect(onLocalDeath)

    task.wait(1)  -- 等角色完全加载
    trackAndAim()
end

humanoidDiedConn = humanoid.Died:Connect(onLocalDeath)

