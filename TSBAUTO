    RunService.Heartbeat:Connect(function()
        if preyAnimDetected then
            preyLbl.Text       = "⚡ 动画反制: 触发！"
            preyLbl.TextColor3 = Color3.fromRGB(255,220,60)
        else
            preyLbl.Text       = "⚡ 动画反制: 待机"
            preyLbl.TextColor3 = Color3.fromRGB(120,140,180)
        end
    end)

    local tpLbl = makeLabel("🌀 瞬移: 待机", 14)
    RunService.Heartbeat:Connect(function()
        if teleportDetected then
            tpLbl.Text       = "🌀 瞬移: 已触发！"
            tpLbl.TextColor3 = Color3.fromRGB(160,120,255)
        else
            tpLbl.Text       = "🌀 瞬移: 待机"
            tpLbl.TextColor3 = Color3.fromRGB(120,140,180)
        end
    end)

    local cdLbl = makeLabel("技能冷却: 就绪 ✔", 14)
    RunService.Heartbeat:Connect(function()
        local remain = CONFIG.skillCooldown - (tick() - lastSkillTime)
        if remain > 0 then
            cdLbl.Text       = string.format("技能冷却: %.1fs", remain)
            cdLbl.TextColor3 = Color3.fromRGB(255,160,80)
        else
            cdLbl.Text       = "技能冷却: 就绪 ✔"
            cdLbl.TextColor3 = Color3.fromRGB(100,220,140)
        end
    end)

    -- ── 收起/展开 ──
    local collapsed = false
    collapseBtn.MouseButton1Click:Connect(function()
        collapsed = not collapsed
        TweenService:Create(panel, TweenInfo.new(0.2,Enum.EasingStyle.Quad), {
            Size = collapsed and UDim2.new(0,240,0,36) or UDim2.new(0,240,0,340)
        }):Play()
        content.Visible  = not collapsed
        collapseBtn.Text = collapsed and "□" or "─"
    end)
end

