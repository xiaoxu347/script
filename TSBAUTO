    statusLabel=Instance.new("TextLabel")
    statusLabel.Size=UDim2.new(1,0,0,48); statusLabel.BackgroundColor3=Color3.fromRGB(22,22,32)
    statusLabel.TextColor3=Color3.fromRGB(120,220,160); statusLabel.TextSize=12
    statusLabel.Font=Enum.Font.Gotham; statusLabel.Text="状态: 启动中..."
    statusLabel.TextXAlignment=Enum.TextXAlignment.Left; statusLabel.TextWrapped=true
    statusLabel.BorderSizePixel=0; statusLabel.Parent=content
    do local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,6); c.Parent=statusLabel end
    do local p=Instance.new("UIPadding"); p.PaddingLeft=UDim.new(0,8); p.PaddingTop=UDim.new(0,4); p.Parent=statusLabel end

    -- 分割线
    do local d=Instance.new("Frame"); d.Size=UDim2.new(1,0,0,1)
       d.BackgroundColor3=Color3.fromRGB(50,55,80); d.BorderSizePixel=0; d.Parent=content end

    -- 开关
    mkToggle("🛡  守卫开关", true, function(on)
        trackEnabled = on
        if on then
            guardAndCombat()
        else
            disconnectAll(); stopAttacking()
            setStatus("状态: ⏸ 已暂停", Color3.fromRGB(160,160,160))
        end
    end)

    -- 指示行
    modeLabel    = mkLabel("模式: 守卫", 14)
    enemyLabel   = mkLabel("敌方: 无", 14)
    ragdollLabel = mkLabel("🪆 布娃娃: 正常", 14)
    preyLabel    = mkLabel("⚡ 动画反制: 待机", 14)
    tpLabel      = mkLabel("🌀 瞬移: 待机", 14)
    cdLabel      = mkLabel("技能冷却: 就绪 ✔", 14)

    RunService.Heartbeat:Connect(function()
        if modeLabel then
            if mode == "guard" then
                modeLabel.Text      = "模式: 🛡 守卫跟随"
                modeLabel.TextColor3= Color3.fromRGB(100, 200, 255)
            else
                modeLabel.Text      = "模式: ⚔ 战斗中"
                modeLabel.TextColor3= Color3.fromRGB(255, 120, 80)
            end
        end
        if enemyLabel then
            if currentEnemy then
                enemyLabel.Text      = "敌方: " .. currentEnemy.Name
                enemyLabel.TextColor3= Color3.fromRGB(255, 160, 80)
            else
                enemyLabel.Text      = "敌方: 无"
                enemyLabel.TextColor3= Color3.fromRGB(120, 140, 180)
            end
        end
        if ragdollLabel then
            ragdollLabel.Text      = enemyIsRagdoll and "🪆 布娃娃: ⚠ 敌方倒地" or "🪆 布娃娃: 正常"
            ragdollLabel.TextColor3= enemyIsRagdoll and Color3.fromRGB(255,180,50) or Color3.fromRGB(100,220,140)
        end
        if preyLabel then
            preyLabel.Text      = preyDetected and "⚡ 动画反制: 触发！" or "⚡ 动画反制: 待机"
            preyLabel.TextColor3= preyDetected and Color3.fromRGB(255,220,60) or Color3.fromRGB(120,140,180)
        end
        if tpLabel then
            tpLabel.Text      = tpDetected and "🌀 瞬移: 已触发！" or "🌀 瞬移: 待机"
            tpLabel.TextColor3= tpDetected and Color3.fromRGB(160,120,255) or Color3.fromRGB(120,140,180)
        end
        if cdLabel then
            local rem = CFG.skillCD - (tick() - lastSkillTime)
            if rem > 0 then
                cdLabel.Text      = string.format("技能冷却: %.1fs", rem)
                cdLabel.TextColor3= Color3.fromRGB(255,160,80)
            else
                cdLabel.Text      = "技能冷却: 就绪 ✔"
                cdLabel.TextColor3= Color3.fromRGB(100,220,140)
            end
        end
    end)

    -- 收起/展开
    local collapsed = false
    colBtn.MouseButton1Click:Connect(function()
        collapsed = not collapsed
        TweenSvc:Create(panel, TweenInfo.new(0.2,Enum.EasingStyle.Quad),{
            Size = collapsed and UDim2.new(0,240,0,36) or UDim2.new(0,240,0,360)
        }):Play()
        content.Visible = not collapsed
        colBtn.Text = collapsed and "□" or "─"
    end)
end

