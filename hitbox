-- Hitbox expansion functions
local function ExpandHitboxes()
	hitboxEnabled = true
	for _, player in pairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local HRP = player.Character:FindFirstChild("HumanoidRootPart")
			HRP.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
			HRP.Transparency = hitboxTransparency
			HRP.Material = Enum.Material.Neon
			HRP.Color = hitboxColor
		end
	end
end
 
local function ResetHitboxes()
	hitboxEnabled = false
	for _, player in pairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local HRP = player.Character:FindFirstChild("HumanoidRootPart")
			HRP.Size = Vector3.new(2, 2, 1)
			HRP.Transparency = 0
			HRP.Material = Enum.Material.Plastic
		end
	end
end
 
local function ApplyHitbox(player)
	if player ~= LocalPlayer then
		player.CharacterAdded:Connect(function(character)
			local HRP = character:WaitForChild("HumanoidRootPart", 5)
			if HRP and hitboxEnabled then
				HRP.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
				HRP.Transparency = hitboxTransparency
				HRP.Material = Enum.Material.Neon
				HRP.Color = hitboxColor
			end
		end)
	end
end
 
-- Color name shortcuts
local colorPresets = {
	red = Color3.fromRGB(255, 0, 0),
	blue = Color3.fromRGB(0, 0, 255),
	green = Color3.fromRGB(0, 255, 0),
	yellow = Color3.fromRGB(255, 255, 0),
	orange = Color3.fromRGB(255, 165, 0),
	purple = Color3.fromRGB(128, 0, 128),
	pink = Color3.fromRGB(255, 105, 180),
	white = Color3.fromRGB(255, 255, 255),
	black = Color3.fromRGB(0, 0, 0),
}
 
ExpandButton.MouseButton1Click:Connect(function()
	local s = tonumber(SizeSlider.Text)
	local t = tonumber(TransparencySlider.Text)
	local colorText = string.lower(ColorPicker.Text)
 
	if s then hitboxSize = s end
	if t and t >= 0 and t <= 1 then hitboxTransparency = t end
 
	if colorPresets[colorText] then
		hitboxColor = colorPresets[colorText]
	else
		local r, g, b = string.match(ColorPicker.Text, "(%d+),%s*(%d+),%s*(%d+)")
		if r and g and b then
			r, g, b = tonumber(r), tonumber(g), tonumber(b)
			if r and g and b then
				hitboxColor = Color3.fromRGB(r, g, b)
			end
		end
	end
 
	ExpandHitboxes()
end)
 
ResetButton.MouseButton1Click:Connect(ResetHitboxes)
 
-- Apply hitboxes to all current players
for _, player in pairs(Players:GetPlayers()) do
	ApplyHitbox(player)
end
