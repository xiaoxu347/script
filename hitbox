--  核心 Hitbox 逻辑
-- ══════════════════════════════════════

-- 对单个 HumanoidRootPart 应用 hitbox（含名称显示）
local function applyToHRP(HRP)
	HRP.Size        = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
	HRP.Transparency= hitboxTransparency
	HRP.Material    = Enum.Material.Neon
	HRP.Color       = hitboxColor

	-- 名称 BillboardGui（避免重复创建）
	if HRP:FindFirstChild("HitboxNameBillboard") then return end
	local playerName = ""
	for _, p in pairs(Players:GetPlayers()) do
		if p.Character and p.Character:FindFirstChild("HumanoidRootPart") == HRP then
			playerName = p.Name
			break
		end
	end

	local billboard = Instance.new("BillboardGui", HRP)
	billboard.Name            = "HitboxNameBillboard"
	billboard.Size            = UDim2.new(0, 120, 0, 30)
	billboard.StudsOffset     = Vector3.new(0, hitboxSize / 2 + 1, 0)
	billboard.AlwaysOnTop     = true
	billboard.LightInfluence  = 0

	local nameLabel = Instance.new("TextLabel", billboard)
	nameLabel.Size             = UDim2.new(1, 0, 1, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text             = playerName
	nameLabel.TextColor3       = Color3.fromRGB(255, 255, 255)
	nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	nameLabel.TextStrokeTransparency = 0.4
	nameLabel.Font             = Enum.Font.GothamBold
	nameLabel.TextSize         = 14
	nameLabel.TextScaled       = false
end

-- 对单个角色监听（角色已存在时直接处理，同时绑定该玩家的后续重生）
local function hookPlayer(player)
	if player == LocalPlayer then return end

	-- 处理已有角色
	if hitboxEnabled and player.Character then
		local HRP = player.Character:FindFirstChild("HumanoidRootPart")
		if HRP then applyToHRP(HRP) end
	end

	-- 绑定该玩家每次重生后自动应用
	player.CharacterAdded:Connect(function(character)
		if not hitboxEnabled then return end
		-- 等 HRP 加载完毕
		local HRP = character:WaitForChild("HumanoidRootPart", 5)
		if HRP then applyToHRP(HRP) end
	end)
end

local function ExpandHitboxes()
	hitboxEnabled = true
	-- 对当前所有玩家立即生效
	for _, player in pairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character then
			local HRP = player.Character:FindFirstChild("HumanoidRootPart")
			if HRP then applyToHRP(HRP) end
		end
	end
end

local function ResetHitboxes()
	hitboxEnabled = false
	for _, player in pairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character then
			local HRP = player.Character:FindFirstChild("HumanoidRootPart")
			if HRP then
				HRP.Size        = Vector3.new(2, 2, 1)
				HRP.Transparency= 0
				HRP.Material    = Enum.Material.Plastic
				local bb = HRP:FindFirstChild("HitboxNameBillboard")
				if bb then bb:Destroy() end
			end
		end
	end
end

-- Color presets
local colorPresets = {
	red    = Color3.fromRGB(255, 0,   0),
	blue   = Color3.fromRGB(0,   0,   255),
	green  = Color3.fromRGB(0,   255, 0),
	yellow = Color3.fromRGB(255, 255, 0),
	orange = Color3.fromRGB(255, 165, 0),
	purple = Color3.fromRGB(128, 0,   128),
	pink   = Color3.fromRGB(255, 105, 180),
	white  = Color3.fromRGB(255, 255, 255),
	black  = Color3.fromRGB(0,   0,   0),
}

ExpandButton.MouseButton1Click:Connect(function()
	local s = tonumber(SizeSlider.Text)
	local t = tonumber(TransparencySlider.Text)
	local colorText = string.lower(ColorPicker.Text)

	if s then hitboxSize = s end
	if t and t >= 0 and t <= 1 then hitboxTransparency = t end

	if colorPresets[colorText] then
		hitboxColor = colorPresets[colorText]
	else
		local r, g, b = string.match(ColorPicker.Text, "(%d+),%s*(%d+),%s*(%d+)")
		if r and g and b then
			r, g, b = tonumber(r), tonumber(g), tonumber(b)
			if r and g and b then
				hitboxColor = Color3.fromRGB(r, g, b) end
		end
	end

	ExpandHitboxes()
end)

ResetButton.MouseButton1Click:Connect(ResetHitboxes)

