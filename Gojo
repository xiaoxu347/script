-- 获取屏幕中心点
local function getScreenCenter()
    local viewportSize = camera.ViewportSize
    return Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
end

-- 将3D位置转换为屏幕坐标
local function worldToScreen(position)
    local screenPoint, onScreen = camera:WorldToScreenPoint(position)
    return Vector2.new(screenPoint.X, screenPoint.Y), onScreen
end

-- 找到离屏幕中心最近的玩家
local function findClosestPlayerToScreenCenter()
    local screenCenter = getScreenCenter()
    local closestPlayer = nil
    local closestDistance = math.huge

    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character and otherPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local screenPos, onScreen = worldToScreen(otherPlayer.Character.HumanoidRootPart.Position)
            if onScreen then
                local distance = (screenCenter - screenPos).Magnitude
                if distance < closestDistance then
                    closestDistance = distance
                    closestPlayer = otherPlayer
                end
            end
        end
    end

    return closestPlayer
end

-- 瞬间自瞄两帧让角色朝向生效（绕过位移锁）
local function snapFaceTarget(targetHRP)
    local prevType = camera.CameraType
    camera.CameraType = Enum.CameraType.Scriptable

    local snapDone = false
    local snapConn
    snapConn = RunService.RenderStepped:Connect(function()
        if not snapDone then
            -- 第1帧：摄像机对准目标，驱动角色朝向
            if targetHRP and targetHRP.Parent then
                local lookAt = targetHRP.Position + Vector3.new(0, 1.5, 0)
                camera.CFrame = CFrame.lookAt(camera.CFrame.Position, lookAt)
            end
            snapDone = true
        else
            -- 第2帧：立即还原
            camera.CameraType = prevType
            snapConn:Disconnect()
        end
    end)
end

-- 检查角色状态是否合法
local function checkCharacter(targetPlayer)
    if not player.Character
        or not player.Character:FindFirstChild("HumanoidRootPart")
        or not player.Character:FindFirstChild("Humanoid") then
        return false, "你的角色不存在或已死亡"
    end
    if player.Character.Humanoid.Health <= 0 then
        return false, "你已死亡，无法传送"
    end
    if not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return false, "目标玩家不存在"
    end
    if targetPlayer.Character:FindFirstChild("Humanoid") and targetPlayer.Character.Humanoid.Health <= 0 then
        return false, "目标玩家已死亡"
    end
    return true, nil
end

-- 核心传送函数，goFront=true 传送到身前，false 传送到身后
local function teleportToPlayer(targetPlayer, goFront)
    local ok, err = checkCharacter(targetPlayer)
    if not ok then return false, err end

    local targetRoot = targetPlayer.Character.HumanoidRootPart
    local targetLook = targetRoot.CFrame.LookVector

    local offset
    if goFront then
        -- 身前：出现在目标面前，与目标面对面
        offset = targetRoot.Position + targetLook * 5
    else
        -- 身后：出现在目标背后
        offset = targetRoot.Position - targetLook * 5
    end

    -- 落在目标同一高度偏上一点，避免卡地
    offset = Vector3.new(offset.X, targetRoot.Position.Y + 3, offset.Z)

    -- 角色面朝目标
    local newCF = CFrame.lookAt(offset, Vector3.new(targetRoot.Position.X, offset.Y, targetRoot.Position.Z))
    player.Character:PivotTo(newCF)

    -- 两帧自瞄让朝向在位移锁下也能生效
    snapFaceTarget(targetRoot)

    return true, "传送成功"
end

-- 按钮反馈通用函数
local function doTeleport(button, defaultText, defaultColor, goFront)
    local closestPlayer = findClosestPlayerToScreenCenter()

    if closestPlayer then
        local success, message = teleportToPlayer(closestPlayer, goFront)
        if success then
            button.Text = "传送成功!"
            button.BackgroundColor3 = Color3.fromRGB(0, 200, 80)
        else
            button.Text = message or "传送失败"
            button.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        end
    else
        button.Text = "未找到目标"
        button.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
    end

    task.delay(2, function()
        button.Text = defaultText
        button.BackgroundColor3 = defaultColor
    end)
end

-- 绑定按钮
behindButton.MouseButton1Click:Connect(function()
    doTeleport(behindButton, "传送到身后 [T]", Color3.fromRGB(0, 162, 255), false)
end)

frontButton.MouseButton1Click:Connect(function()
    doTeleport(frontButton, "传送到身前 [Y]", Color3.fromRGB(255, 100, 0), true)
end)

-- 键盘快捷键
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.T then
        behindButton.MouseButton1Click:Fire()
    elseif input.KeyCode == Enum.KeyCode.Y then
        frontButton.MouseButton1Click:Fire()
    end
end)

print("传送脚本已加载！T=身后 / Y=身前")
