cornerFront.Parent = teleportFrontButton

-- 获取屏幕中心点
local function getScreenCenter()
    local viewportSize = camera.ViewportSize
    return Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
end

-- 将3D位置转换为屏幕坐标
local function worldToScreen(position)
    local screenPoint, onScreen = camera:WorldToScreenPoint(position)
    return Vector2.new(screenPoint.X, screenPoint.Y), onScreen
end

-- 计算两个2D点之间的距离
local function getDistance2D(point1, point2)
    return (point1 - point2).Magnitude
end

-- 找到离屏幕中心最近的玩家
local function findClosestPlayerToScreenCenter()
    local screenCenter = getScreenCenter()
    local closestPlayer = nil
    local closestDistance = math.huge

    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character and otherPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local screenPos, onScreen = worldToScreen(otherPlayer.Character.HumanoidRootPart.Position)
            if onScreen then
                local distance = getDistance2D(screenCenter, screenPos)
                if distance < closestDistance then
                    closestDistance = distance
                    closestPlayer = otherPlayer
                end
            end
        end
    end

    return closestPlayer
end

-- 瞬间自瞄两帧，绕过位移锁，让角色朝向目标
local function snapFaceTarget(targetHRP)
    local prevType = camera.CameraType
    camera.CameraType = Enum.CameraType.Scriptable

    local snapDone = false
    local snapConn
    snapConn = RunService.RenderStepped:Connect(function()
        if not snapDone then
            -- 第1帧：摄像机直接对准目标，驱动角色朝向
            local aimPos = targetHRP and targetHRP.Parent
                and (targetHRP.Position + Vector3.new(0, 1.5, 0))
                or (camera.CFrame.Position + camera.CFrame.LookVector * 100)
            camera.CFrame = CFrame.lookAt(camera.CFrame.Position, aimPos)
            snapDone = true
        else
            -- 第2帧：还原摄像机，结束
            camera.CameraType = prevType
            snapConn:Disconnect()
        end
    end)
end

-- 核心传送函数，goFront=true 传到面前，false 传到身后
local function teleportToPlayer(targetPlayer, goFront)
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
        return false, "你的角色不存在或已死亡"
    end

    local humanoid = player.Character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        return false, "你已死亡，无法传送"
    end

    if not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return false, "目标玩家不存在"
    end

    local targetHumanoid = targetPlayer.Character:FindFirstChild("Humanoid")
    if targetHumanoid and targetHumanoid.Health <= 0 then
        return false, "目标玩家已死亡"
    end

    local targetRoot = targetPlayer.Character.HumanoidRootPart
    local targetLook = targetRoot.CFrame.LookVector

    -- 身前：目标正前方面对面；身后：目标背后
    local offset = goFront
        and (targetRoot.Position + targetLook * 5)
        or  (targetRoot.Position - targetLook * 5)

    -- 落点高度对齐目标，防止卡地板
    local teleportPos = Vector3.new(offset.X, targetRoot.Position.Y, offset.Z)

    -- 角色面向目标
    local newCF = CFrame.lookAt(teleportPos, Vector3.new(targetRoot.Position.X, teleportPos.Y, targetRoot.Position.Z))
    player.Character:PivotTo(newCF)

    -- 自瞄两帧绕过位移锁，确保角色朝向生效
    snapFaceTarget(targetRoot)

    return true, "传送成功"
end

-- 按钮反馈工具函数
local function setButtonFeedback(btn, text, color, originalText, originalColor)
    btn.Text = text
    btn.BackgroundColor3 = color
    task.delay(2, function()
        btn.Text = originalText
        btn.BackgroundColor3 = originalColor
    end)
end

-- 身后按钮
teleportBehindButton.MouseButton1Click:Connect(function()
    local target = findClosestPlayerToScreenCenter()
    if target then
        local success, msg = teleportToPlayer(target, false)
        if success then
            setButtonFeedback(teleportBehindButton, "传送成功!", Color3.fromRGB(0,200,80), "传送到玩家身后", Color3.fromRGB(0,162,255))
        else
            setButtonFeedback(teleportBehindButton, msg or "传送失败", Color3.fromRGB(255,0,0), "传送到玩家身后", Color3.fromRGB(0,162,255))
        end
    else
        setButtonFeedback(teleportBehindButton, "未找到目标", Color3.fromRGB(255,165,0), "传送到玩家身后", Color3.fromRGB(0,162,255))
    end
end)

-- 身前按钮
teleportFrontButton.MouseButton1Click:Connect(function()
    local target = findClosestPlayerToScreenCenter()
    if target then
        local success, msg = teleportToPlayer(target, true)
        if success then
            setButtonFeedback(teleportFrontButton, "传送成功!", Color3.fromRGB(0,200,80), "传送到玩家面前", Color3.fromRGB(255,120,0))
        else
            setButtonFeedback(teleportFrontButton, msg or "传送失败", Color3.fromRGB(255,0,0), "传送到玩家面前", Color3.fromRGB(255,120,0))
        end
    else
        setButtonFeedback(teleportFrontButton, "未找到目标", Color3.fromRGB(255,165,0), "传送到玩家面前", Color3.fromRGB(255,120,0))
    end
end)

-- 键盘快捷键：T=身后，Y=身前
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.T then
        teleportBehindButton.MouseButton1Click:Fire()
    elseif input.KeyCode == Enum.KeyCode.Y then
        teleportFrontButton.MouseButton1Click:Fire()
    end
end)

print("传送脚本已加载！T键=身后 / Y键=身前")
