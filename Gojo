    minimized = not minimized
    btnContainer.Visible = not minimized
    frame.Size = minimized and UDim2.new(0, 150, 0, 24) or UDim2.new(0, 150, 0, 90)
    minBtn.Text = minimized and "+" or "−"
end)

-- 工具函数
local function getScreenCenter()
    local v = camera.ViewportSize
    return Vector2.new(v.X / 2, v.Y / 2)
end

local function findClosestPlayer()
    local center = getScreenCenter()
    local closest, minDist = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local sp, onScreen = camera:WorldToScreenPoint(p.Character.HumanoidRootPart.Position)
            if onScreen then
                local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
                if d < minDist then minDist = d; closest = p end
            end
        end
    end
    return closest
end

local function canTeleport()
    local c = player.Character
    return c and c:FindFirstChild("HumanoidRootPart") and c:FindFirstChild("Humanoid") and c.Humanoid.Health > 0
end

local function teleport(offset)
    if not canTeleport() then return false, "你已死亡" end
    local target = findClosestPlayer()
    if not target then return false, "无目标" end
    local tr = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    if not tr then return false, "目标不存在" end

    local dir = tr.CFrame.LookVector * offset
    local pos = tr.Position + dir + Vector3.new(0, 3, 0)
    player.Character.HumanoidRootPart.CFrame = CFrame.new(pos, tr.Position)
    
    -- 摄像头朝向目标玩家
    local lookDir = (tr.Position - pos).Unit
    camera.CFrame = CFrame.lookAt(camera.CFrame.Position, camera.CFrame.Position + lookDir)
    
    return true, "成功"
end

-- 按钮反馈
local function feedback(btn, origText, origColor, ok)
    btn.Text = ok and "✓ 成功" or "✗ 失败"
    btn.BackgroundColor3 = ok and Color3.fromRGB(0, 200, 80) or Color3.fromRGB(220, 50, 50)
    task.delay(1.5, function()
        btn.Text = origText
        btn.BackgroundColor3 = origColor
    end)
end

behindBtn.MouseButton1Click:Connect(function()
    local ok, _ = teleport(-7)
    feedback(behindBtn, "⬅ 传送到身后", Color3.fromRGB(0, 130, 210), ok)
end)

frontBtn.MouseButton1Click:Connect(function()
    local ok, _ = teleport(7)
    feedback(frontBtn, "➡ 传送到身前", Color3.fromRGB(150, 60, 200), ok)
end)

-- 快捷键：T=身后，Y=身前
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.E then behindBtn.MouseButton1Click:Fire() end
    if input.KeyCode == Enum.KeyCode.R then frontBtn.MouseButton1Click:Fire() end
end)

