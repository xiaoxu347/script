-- 传送到最近玩家身后的脚本
-- 适用于Roblox客户端脚本

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local camera = workspace.CurrentCamera

-- 创建或获取GUI（防止重复创建）
local screenGui = playerGui:FindFirstChild("TeleportGui")
if screenGui then
    screenGui:Destroy()
end

screenGui = Instance.new("ScreenGui")
screenGui.Name = "TeleportGui"
screenGui.ResetOnSpawn = false  -- 关键：防止重生时GUI消失
screenGui.Parent = playerGui

-- 创建按钮
local teleportButton = Instance.new("TextButton")
teleportButton.Name = "TeleportButton"
teleportButton.Size = UDim2.new(0, 200, 0, 50)
teleportButton.Position = UDim2.new(0, 10, 0, 10)
teleportButton.BackgroundColor3 = Color3.fromRGB(0, 162, 255)
teleportButton.BorderSizePixel = 0
teleportButton.Text = "传送到最近玩家"
teleportButton.TextColor3 = Color3.fromRGB(255, 255, 255)
teleportButton.TextSize = 18
teleportButton.Font = Enum.Font.SourceSansBold
teleportButton.Parent = screenGui

-- 添加圆角效果
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = teleportButton

-- 获取屏幕中心点
local function getScreenCenter()
    local viewportSize = camera.ViewportSize
    return Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
end

-- 将3D位置转换为屏幕坐标
local function worldToScreen(position)
    local screenPoint, onScreen = camera:WorldToScreenPoint(position)
    return Vector2.new(screenPoint.X, screenPoint.Y), onScreen
end

-- 计算两个2D点之间的距离
local function getDistance2D(point1, point2)
    return (point1 - point2).Magnitude
end

-- 找到离屏幕中心最近的玩家
local function findClosestPlayerToScreenCenter()
    local screenCenter = getScreenCenter()
    local closestPlayer = nil
    local closestDistance = math.huge
    
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character and otherPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local screenPos, onScreen = worldToScreen(otherPlayer.Character.HumanoidRootPart.Position)
            
            -- 只考虑在屏幕上可见的玩家
            if onScreen then
                local distance = getDistance2D(screenCenter, screenPos)
                if distance < closestDistance then
                    closestDistance = distance
                    closestPlayer = otherPlayer
                end
            end
        end
    end
    
    return closestPlayer
end

-- 传送到目标玩家身后
local function teleportBehindPlayer(targetPlayer)
    -- 检查当前玩家是否存在且活着
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") or not player.Character:FindFirstChild("Humanoid") then
        return false, "你的角色不存在或已死亡"
    end
    
    -- 检查玩家是否死亡
    if player.Character.Humanoid.Health <= 0 then
        return false, "你已死亡，无法传送"
    end
    
    if not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return false, "目标玩家不存在"
    end
    
    -- 检查目标玩家是否死亡
    if targetPlayer.Character:FindFirstChild("Humanoid") and targetPlayer.Character.Humanoid.Health <= 0 then
        return false, "目标玩家已死亡"
    end
    
    local targetRoot = targetPlayer.Character.HumanoidRootPart
    local playerRoot = player.Character.HumanoidRootPart
    
    -- 计算目标玩家的朝向
    local targetLookVector = targetRoot.CFrame.LookVector
    
    -- 计算身后位置（距离目标玩家背后5个单位）
    local behindPosition = targetRoot.Position - targetLookVector * 5
    
    -- 确保位置在地面上方（避免卡在地下）
    behindPosition = behindPosition + Vector3.new(0, 3, 0)
    
    -- 传送玩家
    playerRoot.CFrame = CFrame.new(behindPosition, targetRoot.Position)
    
    -- 调整相机视角朝向目标玩家
    local lookDirection = (targetRoot.Position - behindPosition).Unit
    camera.CFrame = CFrame.lookAt(camera.CFrame.Position, camera.CFrame.Position + lookDirection)
    
    return true, "传送成功"
end

-- 按钮点击事件
teleportButton.MouseButton1Click:Connect(function()
    local closestPlayer = findClosestPlayerToScreenCenter()
    
    if closestPlayer then
        local success, message = teleportBehindPlayer(closestPlayer)
        if success then
            -- 成功传送的反馈
            teleportButton.Text = "传送成功!"
            teleportButton.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        else
            -- 传送失败的反馈
            teleportButton.Text = message or "传送失败"
            teleportButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        end
    else
        -- 没有找到目标玩家的反馈
        teleportButton.Text = "未找到目标"
        teleportButton.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
    end
    
    -- 2秒后恢复按钮状态
    wait(2)
    teleportButton.Text = "传送到最近玩家"
    teleportButton.BackgroundColor3 = Color3.fromRGB(0, 162, 255)
end)

-- 可选：添加键盘快捷键（按T键）
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.T then
        teleportButton.MouseButton1Click:Fire()
    end
end)

print("传送脚本已加载！点击按钮或按T键传送到最近的玩家身后。")   直接修改这个脚本，添加个传送到目标玩家面前的脚本。
