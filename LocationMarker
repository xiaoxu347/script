local function makeBtn(text, color, order)
    local btn = Instance.new("TextButton", btnRow)
    btn.Size             = UDim2.new(0, 72, 1, 0)
    btn.BackgroundColor3 = color
    btn.TextColor3       = Color3.fromRGB(255, 255, 255)
    btn.Text             = text
    btn.TextSize         = 12
    btn.Font             = Enum.Font.GothamBold
    btn.BorderSizePixel  = 0
    btn.LayoutOrder      = order
    do local c = Instance.new("UICorner", btn); c.CornerRadius = UDim.new(0, 8) end
    -- 悬停效果
    local orig = color
    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.new(
            math.min(orig.R + 0.15, 1),
            math.min(orig.G + 0.15, 1),
            math.min(orig.B + 0.15, 1))
    end)
    btn.MouseLeave:Connect(function() btn.BackgroundColor3 = orig end)
    return btn
end

