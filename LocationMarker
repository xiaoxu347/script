-- ══════════════════════════════════════
--  世界场景标记（发光小球 + 名称牌）
-- ══════════════════════════════════════
local markerFolder = workspace:FindFirstChild("_MarkerFolder")
    or (function()
        local f = Instance.new("Folder", workspace)
        f.Name = "_MarkerFolder"
        return f
    end)()

local MARKER_COLORS = {
    Color3.fromRGB(80,  200, 255),
    Color3.fromRGB(255, 180, 60),
    Color3.fromRGB(120, 255, 140),
    Color3.fromRGB(255, 100, 160),
    Color3.fromRGB(200, 140, 255),
    Color3.fromRGB(255, 220, 80),
}

local function createWorldMarker(position, id, color)
    -- 发光球
    local part = Instance.new("Part", markerFolder)
    part.Name      = "Marker_" .. id
    part.Shape     = Enum.PartType.Ball
    part.Size      = Vector3.new(1.2, 1.2, 1.2)
    part.CFrame    = CFrame.new(position)
    part.Anchored  = true
    part.CanCollide= false
    part.Material  = Enum.Material.Neon
    part.Color     = color
    part.CastShadow= false

    -- 脉冲动画（缩放）
    local function pulse()
        TweenService:Create(part, TweenInfo.new(0.7, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
            { Size = Vector3.new(1.6, 1.6, 1.6) }):Play()
    end
    pulse()

    -- BillboardGui 名称牌
    local bb = Instance.new("BillboardGui", part)
    bb.Size          = UDim2.new(0, 100, 0, 28)
    bb.StudsOffset   = Vector3.new(0, 2.2, 0)
    bb.AlwaysOnTop   = true
    bb.LightInfluence= 0

    local lbl = Instance.new("TextLabel", bb)
    lbl.Size                  = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundTransparency= 1
    lbl.Text                  = "📍 #" .. id
    lbl.TextColor3            = color
    lbl.TextStrokeColor3      = Color3.fromRGB(0, 0, 0)
    lbl.TextStrokeTransparency= 0.3
    lbl.Font                  = Enum.Font.GothamBold
    lbl.TextSize               = 13

    return part, bb, lbl
end

