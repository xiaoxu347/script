    -- 坐标文字
    local lbl = Instance.new("TextLabel", row)
    lbl.Size             = UDim2.new(1, -80, 1, 0)
    lbl.Position         = UDim2.new(0, 22, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text             = string.format("#%d  (%.0f, %.0f, %.0f)", id, pos.X, pos.Y, pos.Z)
    lbl.TextColor3       = Color3.fromRGB(200, 210, 230)
    lbl.TextSize         = 11
    lbl.Font             = Enum.Font.Gotham
    lbl.TextXAlignment   = Enum.TextXAlignment.Left

    -- 单独传送按钮
    local goBtn = Instance.new("TextButton", row)
    goBtn.Size             = UDim2.new(0, 40, 0, 20)
    goBtn.Position         = UDim2.new(1, -48, 0.5, -10)
    goBtn.BackgroundColor3 = Color3.fromRGB(30, 100, 200)
    goBtn.TextColor3       = Color3.fromRGB(255, 255, 255)
    goBtn.Text             = "去"
    goBtn.TextSize         = 11
    goBtn.Font             = Enum.Font.GothamBold
    goBtn.BorderSizePixel  = 0
    do local c = Instance.new("UICorner", goBtn); c.CornerRadius = UDim.new(0, 5) end
    goBtn.MouseButton1Click:Connect(function()
        local char = LP.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then
            root.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
            statusLbl.Text      = string.format("✅ 已传送到 #%d", id)
            statusLbl.TextColor3= Color3.fromRGB(100, 220, 140)
        end
    end)

    return row
end

-- ══════════════════════════════════════
--  核心功能
-- ══════════════════════════════════════

-- 刷新状态文字
local function refreshStatus()
    if #markers == 0 then
        statusLbl.Text      = "尚未标记任何位置"
        statusLbl.TextColor3= Color3.fromRGB(130, 150, 190)
    else
        statusLbl.Text      = string.format("共 %d 个标点", #markers)
        statusLbl.TextColor3= Color3.fromRGB(160, 200, 255)
    end
end

-- 标记当前位置
markBtn.MouseButton1Click:Connect(function()
    local char = LP.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    markerCount = markerCount + 1
    local id    = markerCount
    local pos   = root.Position
    local color = MARKER_COLORS[(id - 1) % #MARKER_COLORS + 1]

    local worldPart, bb, lbl = createWorldMarker(pos, id, color)
    local row                = createMarkerRow(id, pos, color)

    table.insert(markers, {
        id        = id,
        position  = pos,
        part      = worldPart,
        billboard = bb,
        label     = lbl,
        row       = row,
        color     = color,
    })

    statusLbl.Text      = string.format("✅ 标点 #%d 已记录", id)
    statusLbl.TextColor3= Color3.fromRGB(100, 220, 140)
    task.delay(1.5, refreshStatus)
end)

-- 传送：优先传送到距屏幕中心最近的标点
tpBtn.MouseButton1Click:Connect(function()
    if #markers == 0 then
        statusLbl.Text      = "⚠ 没有可用的标点"
        statusLbl.TextColor3= Color3.fromRGB(255, 180, 60)
        return
    end

    local vpSize    = camera.ViewportSize
    local screenCenter = Vector2.new(vpSize.X / 2, vpSize.Y / 2)

    local bestMarker  = nil
    local bestDist    = math.huge

    for _, m in ipairs(markers) do
        -- 将世界坐标投影到屏幕
        local screenPos, onScreen = camera:WorldToScreenPoint(m.position)
        local dist2D
        if onScreen then
            dist2D = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
        else
            -- 不在屏幕内时给一个很大的偏移，但仍参与比较（相机后方用极大值排除）
            if screenPos.Z < 0 then
                dist2D = math.huge
            else
                dist2D = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude + 5000
            end
        end

        if dist2D < bestDist then
            bestDist   = dist2D
            bestMarker = m
        end
    end

    if bestMarker then
        local char = LP.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then
            root.CFrame = CFrame.new(bestMarker.position + Vector3.new(0, 3, 0))
            statusLbl.Text      = string.format("⚡ 传送至 #%d（屏幕最近）", bestMarker.id)
            statusLbl.TextColor3= Color3.fromRGB(100, 200, 255)
        end
    end
end)

-- 清空所有标点
clearBtn.MouseButton1Click:Connect(function()
    for _, m in ipairs(markers) do
        pcall(function() m.part:Destroy() end)
        pcall(function() m.row:Destroy() end)
    end
    markers      = {}
    markerCount  = 0
    refreshStatus()
end)
